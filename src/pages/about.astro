---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company, milestones, techHighlights } from '../data/company.ts';

const techIcons: Record<string, string> = {
  'AI 기반 분석': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6a3 3 0 0 1 3-3h1V6a4 4 0 0 1 4-4z"/><circle cx="9" cy="13" r="1.5" fill="currentColor" stroke="none"/><circle cx="15" cy="13" r="1.5" fill="currentColor" stroke="none"/><path d="M9 17c1 .667 5 .667 6 0"/></svg>`,
  '다계층 방어': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
  '한국 규정 최적화': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M7 8h10M7 12h6M7 16h8"/></svg>`,
  '유연한 배포': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><circle cx="17" cy="7" r="2"/><path d="M15 7h-6"/></svg>`,
};
---

<Layout
  title="회사 소개 | BlueSecurity"
  description="BlueSecurity의 미션, 비전, 기술 역량을 소개합니다. 한국 중소기업 보안의 표준을 만들어 갑니다."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-grid pt-32 pb-20">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-b from-blue-950/30 via-transparent to-transparent"
    >
    </div>
    <div class="relative mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm font-semibold tracking-[0.2em] text-blue-400 uppercase">
        Company
      </p>
      <h1 class="mb-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        회사 소개
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-slate-400 leading-relaxed">
        {company.description}
      </p>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2">
        <!-- Mission -->
        <div
          class="relative overflow-hidden rounded-2xl border border-blue-900/50 bg-navy-800 p-8 card-hover"
        >
          <div
            class="pointer-events-none absolute -right-10 -top-10 h-40 w-40 rounded-full bg-blue-600/10 blur-2xl"
          >
          </div>
          <div class="relative">
            <div
              class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-blue-900/60 text-blue-400"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 8v4l3 3"></path>
              </svg>
            </div>
            <h2 class="mb-3 text-xl font-bold text-white">미션</h2>
            <p class="text-base text-slate-300 leading-relaxed">{company.mission}</p>
          </div>
        </div>

        <!-- Vision -->
        <div
          class="relative overflow-hidden rounded-2xl border border-cyan-900/50 bg-navy-800 p-8 card-hover"
        >
          <div
            class="pointer-events-none absolute -right-10 -top-10 h-40 w-40 rounded-full bg-cyan-600/10 blur-2xl"
          >
          </div>
          <div class="relative">
            <div
              class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-900/60 text-cyan-400"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polygon
                  points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
                ></polygon>
              </svg>
            </div>
            <h2 class="mb-3 text-xl font-bold text-white">비전</h2>
            <p class="text-base text-slate-300 leading-relaxed">{company.vision}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CEO Introduction -->
  <section class="py-16 border-y border-blue-900/30 bg-navy-800/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center gap-8 sm:flex-row sm:items-start sm:gap-12">
        <!-- Avatar placeholder -->
        <div class="relative shrink-0">
          <div
            class="relative flex h-28 w-28 items-center justify-center overflow-hidden rounded-2xl border-2 border-blue-700/60 bg-navy-700 pulse-ring"
          >
            <svg
              class="h-14 w-14 text-blue-400/60"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5.33 0-8 2.67-8 4v1h16v-1c0-1.33-2.67-4-8-4z"
              ></path>
            </svg>
          </div>
        </div>

        <!-- Bio -->
        <div>
          <p class="mb-1 text-sm font-semibold tracking-widest text-blue-400 uppercase">
            대표이사
          </p>
          <h2 class="mb-3 text-3xl font-extrabold text-white">{company.ceo}</h2>
          <p class="mb-4 max-w-xl text-slate-400 leading-relaxed">
            보안 기술의 높은 장벽을 낮춰 모든 기업이 세계 수준의 사이버보안 역량을 갖출 수 있어야
            한다는 신념으로 {company.name}을 창립했습니다. 개발자 친화적인 설계와 AI 기반의 정밀
            분석으로 국내 중소기업 보안 생태계를 바꿔나가고 있습니다.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="rounded-full border border-blue-800 bg-blue-900/30 px-3 py-1 text-xs font-medium text-blue-300"
            >
              사이버보안
            </span>
            <span
              class="rounded-full border border-blue-800 bg-blue-900/30 px-3 py-1 text-xs font-medium text-blue-300"
            >
              AI / ML
            </span>
            <span
              class="rounded-full border border-blue-800 bg-blue-900/30 px-3 py-1 text-xs font-medium text-blue-300"
            >
              DevSecOps
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Milestones Timeline -->
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="mb-2 text-sm font-semibold tracking-[0.2em] text-blue-400 uppercase">
          History
        </p>
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">주요 연혁</h2>
      </div>

      <!-- Vertical timeline -->
      <div class="relative mx-auto max-w-2xl">
        <!-- Vertical line -->
        <div
          class="absolute left-1/2 top-0 h-full w-px -translate-x-1/2 bg-gradient-to-b from-blue-700/60 via-blue-800/40 to-transparent"
        >
        </div>

        <div class="space-y-10">
          {
            milestones.map((m, idx) => {
              const isLeft = idx % 2 === 0;
              return (
                <div class={`relative flex items-center ${isLeft ? 'flex-row' : 'flex-row-reverse'}`}>
                  {/* Content side */}
                  <div class={`w-[calc(50%-2rem)] ${isLeft ? 'pr-6 text-right' : 'pl-6 text-left'}`}>
                    <div class="inline-block rounded-xl border border-blue-900/50 bg-navy-800 px-4 py-3 card-hover">
                      <p class="text-xs font-bold text-blue-400 mb-0.5">{m.year}</p>
                      <p class="text-sm font-semibold text-white">{m.event}</p>
                    </div>
                  </div>

                  {/* Center dot */}
                  <div class="absolute left-1/2 -translate-x-1/2 flex h-8 w-8 items-center justify-center">
                    <div class="h-3 w-3 rounded-full border-2 border-blue-400 bg-navy-900 ring-4 ring-blue-900/40" />
                  </div>

                  {/* Spacer opposite side */}
                  <div class="w-[calc(50%-2rem)]" />
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Highlights -->
  <section class="py-20 bg-navy-800/40 border-t border-blue-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="mb-2 text-sm font-semibold tracking-[0.2em] text-blue-400 uppercase">
          Technology
        </p>
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">핵심 기술</h2>
        <p class="mt-3 text-slate-400">
          검증된 기술 스택으로 기업급 보안을 합리적 비용에 제공합니다.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 stagger-children">
        {
          techHighlights.map((tech) => (
            <div class="group flex flex-col gap-4 rounded-2xl border border-blue-900/50 bg-navy-800 p-6 card-hover">
              {/* Icon */}
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-900/60 text-blue-400 group-hover:bg-blue-800/80 transition-colors duration-200">
                <Fragment set:html={techIcons[tech.title] ?? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/></svg>'} />
              </div>
              {/* Text */}
              <div>
                <h3 class="mb-1.5 font-bold text-white">{tech.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{tech.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="relative overflow-hidden rounded-2xl border border-blue-700/40 bg-navy-700 p-10 text-center glow-blue"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-br from-blue-700/10 via-transparent to-cyan-700/10"
        >
        </div>
        <div class="relative">
          <h2 class="mb-3 text-2xl font-extrabold text-white sm:text-3xl">
            보안의 민주화, 함께 시작하세요
          </h2>
          <p class="mb-6 text-slate-400">
            제품 데모 또는 도입 상담이 필요하시면 언제든지 문의해 주세요.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="/contact"
              class="rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-900/50 transition-all duration-200 hover:bg-blue-500"
            >
              문의하기
            </a>
            <a
              href="/products"
              class="rounded-xl border border-blue-700 px-6 py-3 text-sm font-semibold text-slate-200 transition-all duration-200 hover:border-blue-500 hover:text-white"
            >
              제품 살펴보기
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
