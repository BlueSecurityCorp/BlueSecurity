---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/index';
import { t } from '../i18n/ui';
import { getCompany, getTechHighlights } from '../data/company';

const lang = 'ko' as Locale;
const company = getCompany(lang);
const techHighlights = getTechHighlights(lang);

const techIcons: Record<string, string> = {
  '필요한 범위부터 시작': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6a3 3 0 0 1 3-3h1V6a4 4 0 0 1 4-4z"/><circle cx="9" cy="13" r="1.5" fill="currentColor" stroke="none"/><circle cx="15" cy="13" r="1.5" fill="currentColor" stroke="none"/><path d="M9 17c1 .667 5 .667 6 0"/></svg>`,
  '개발 흐름에 맞춘 연동': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><circle cx="17" cy="7" r="2"/><path d="M15 7h-6"/></svg>`,
  '기준 기반 분류': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M7 8h10M7 12h6M7 16h8"/></svg>`,
  '조치 중심 결과물': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
};
---

<Layout
  title={t('about.title', lang)}
  description={t('about.meta', lang)}
>
  <Header slot="header" lang={lang} />

  <!-- Hero -->
  <section class="border-b border-slate-800 bg-navy-900 pt-24 pb-10">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-blue-300">
        {t('about.eyebrow', lang)}
      </p>
      <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl">
        {t('about.heading', lang)}
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-slate-400">
        {company.description}
      </p>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="border-b border-slate-800 bg-navy-900 py-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-4 sm:grid-cols-2">
        <!-- Mission -->
        <div
          class="rounded-lg border border-slate-800 bg-navy-900 p-6"
        >
          <h2 class="mb-3 text-xl font-semibold text-white">{t('about.mission', lang)}</h2>
          <p class="text-base leading-7 text-slate-400">{company.mission}</p>
        </div>

        <!-- Vision -->
        <div
          class="rounded-lg border border-slate-800 bg-navy-900 p-6"
        >
          <h2 class="mb-3 text-xl font-semibold text-white">{t('about.vision', lang)}</h2>
          <p class="text-base leading-7 text-slate-400">{company.vision}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Highlights -->
  <section class="border-b border-slate-800 bg-slate-950/40 py-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 grid gap-4 lg:grid-cols-[320px_1fr] lg:items-end">
        <p class="text-sm font-semibold uppercase tracking-widest text-blue-300">
          {t('about.tech.eyebrow', lang)}
        </p>
        <div>
          <h2 class="text-3xl font-semibold text-white sm:text-4xl">{t('about.tech.heading', lang)}</h2>
          <p class="mt-3 max-w-2xl text-slate-400">{t('about.tech.subtitle', lang)}</p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          techHighlights.map((tech) => (
            <div class="rounded-lg border border-slate-800 bg-navy-900 p-6">
              <h3 class="mb-2 font-semibold text-white">{tech.title}</h3>
              <p class="text-sm leading-6 text-slate-400">{tech.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="bg-navy-900 py-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid items-center gap-6 rounded-lg border border-slate-800 bg-slate-950/50 p-8 md:grid-cols-[1fr_auto]">
        <div>
          <h2 class="text-2xl font-semibold text-white">
            {t('about.cta', lang)}
          </h2>
          <p class="mt-3 max-w-2xl text-slate-400">
            {t('about.cta.description', lang)}
          </p>
        </div>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-500"
            >
              {t('common.contact', lang)}
            </a>
            <a
              href="/products"
              class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-500 hover:bg-slate-900"
            >
              {t('about.cta.products', lang)}
            </a>
          </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</Layout>
