---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/index';
import { t } from '../i18n/ui';
import { getCompany } from '../data/company';
import { getCollection } from 'astro:content';

const lang = 'ko' as Locale;
const company = getCompany(lang);

const today = new Date().toISOString().split('T')[0];
const allPositions = await getCollection('careers');
const positions = allPositions
  .filter((p) => {
    if (p.id.split('/').pop()?.startsWith('_')) return false;
    if (!p.data.published) return false;
    if (p.data.start_date && p.data.start_date > today) return false;
    if (p.data.end_date && p.data.end_date < today) return false;
    return true;
  })
  .sort((a, b) => a.data.order - b.data.order);

function formatPeriod(start?: string, end?: string): string {
  if (!start && !end) return t('careers.period.open', lang);
  const parts = [];
  if (start) parts.push(start);
  parts.push('~');
  if (end) parts.push(end);
  else parts.push(t('careers.period.open', lang));
  return parts.join(' ');
}

const benefits = [
  {
    key: 'growth' as const,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  },
  {
    key: 'culture' as const,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    key: 'impact' as const,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
  },
  {
    key: 'compensation' as const,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><path d="M12 14h.01"/></svg>`,
  },
];
---

<Layout
  title={t('careers.title', lang)}
  description={t('careers.meta', lang)}
>
  <Header slot="header" lang={lang} />

  <!-- Hero -->
  <section class="border-b border-slate-800 bg-navy-900 pt-28 pb-14">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue-300">
        {t('careers.eyebrow', lang)}
      </p>
      <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl">
        {t('careers.heading', lang)}
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-400">
        {t('careers.subtitle', lang)}
      </p>
    </div>
  </section>

  <!-- Why Join Us -->
  <section class="border-b border-slate-800 bg-navy-900 py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-10 grid gap-4 lg:grid-cols-[320px_1fr] lg:items-end">
        <p class="text-sm font-semibold uppercase tracking-widest text-blue-300">Team</p>
        <div>
          <h2 class="text-3xl font-semibold text-white sm:text-4xl">{t('careers.why.heading', lang)}</h2>
          <p class="mt-3 max-w-2xl text-slate-400">{t('careers.why.subtitle', lang)}</p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {benefits.map((b) => (
          <div class="flex gap-4 rounded-lg border border-slate-800 bg-navy-900 p-6">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg border border-slate-800 text-blue-300">
              <Fragment set:html={b.icon} />
            </div>
            <div>
              <h3 class="mb-1.5 font-semibold text-white">{t(`careers.benefit.${b.key}`, lang)}</h3>
              <p class="text-sm leading-6 text-slate-400">{t(`careers.benefit.${b.key}.desc`, lang)}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Positions -->
  <section class="border-b border-slate-800 bg-slate-950/40 py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-10 grid gap-4 lg:grid-cols-[320px_1fr] lg:items-end">
        <p class="text-sm font-semibold uppercase tracking-widest text-blue-300">Open Roles</p>
        <div>
          <h2 class="text-3xl font-semibold text-white sm:text-4xl">{t('careers.positions.heading', lang)}</h2>
          <p class="mt-3 max-w-2xl text-slate-400">
            {positions.length > 0 ? t('careers.positions.subtitle', lang) : t('careers.positions.empty', lang)}
          </p>
        </div>
      </div>

      {positions.length > 0 && (
        <div class="space-y-4">
          {positions.map((pos) => (
            <div class="rounded-lg border border-slate-800 bg-navy-900 p-6">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-bold text-white mb-2">{pos.data.title_ko}</h3>
                  <p class="text-sm text-slate-400 leading-relaxed mb-3" set:html={pos.data.description_ko.trim().replace(/\n/g, '<br>')} />
                  <div class="flex flex-wrap gap-2">
                    <span class="inline-flex items-center rounded-md border border-slate-800 px-2.5 py-0.5 text-xs font-medium text-blue-300">
                      {pos.data.team}
                    </span>
                    <span class="inline-flex items-center rounded-md border border-slate-800 px-2.5 py-0.5 text-xs font-medium text-slate-300">
                      {pos.data.type_ko}
                    </span>
                    <span class="inline-flex items-center rounded-md border border-slate-800 px-2.5 py-0.5 text-xs font-medium text-slate-300">
                      {pos.data.location_ko}
                    </span>
                    <span class="inline-flex items-center gap-1 rounded-md border border-slate-800 px-2.5 py-0.5 text-xs font-medium text-slate-300">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                      {formatPeriod(pos.data.start_date, pos.data.end_date)}
                    </span>
                  </div>
                </div>
                <div class="flex flex-col items-start gap-1.5 shrink-0 sm:items-center sm:self-center">
                  <a
                    href={`mailto:${company.email}?subject=[지원] ${pos.data.title_ko}`}
                    class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-blue-500"
                  >
                    {t('careers.apply', lang)}
                  </a>
                  <span class="inline-flex items-center gap-1 text-xs text-slate-500">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
                    {company.email}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900 py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid items-center gap-6 rounded-lg border border-slate-800 bg-slate-950/50 p-8 md:grid-cols-[1fr_auto]">
        <div>
          <h2 class="text-2xl font-semibold text-white">
            {t('careers.apply.cta.heading', lang)}
          </h2>
          <p class="mt-3 max-w-2xl text-slate-400">
            {t('careers.apply.cta.description', lang)}
          </p>
        </div>
          <a
            href={`mailto:${company.email}?subject=[채용 지원]`}
            class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-500"
          >
            {t('careers.apply.cta.button', lang)}
          </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</Layout>
