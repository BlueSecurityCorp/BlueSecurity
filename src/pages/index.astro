---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import TrustIndicators from '../components/TrustIndicators.astro';
import CTA from '../components/CTA.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import type { Locale } from '../i18n/index';
import { t } from '../i18n/ui';
import { getProducts } from '../data/products';
import { getCompany } from '../data/company';

const lang = 'ko' as Locale;
const products = getProducts(lang);
const company = getCompany(lang);
---

<Layout
  title={`${company.name} - ${company.slogan}`}
  description={company.description}
>
  <!-- Header injected into named slot -->
  <Header slot="header" lang={lang} />

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <Hero lang={lang} />

  <!-- ── Products ──────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-navy-900 py-24"
    aria-labelledby="products-heading"
  >
    <!-- Subtle top fade from hero -->
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-navy-900 to-transparent"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <!-- Section header -->
      <div class="mb-16 text-center">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-blue-400">
          {t('products.eyebrow', lang)}
        </p>
        <h2
          id="products-heading"
          class="text-4xl font-black text-white md:text-5xl"
        >
          {t('products.heading', lang)}
          <span class="text-gradient">{t('products.heading.accent', lang)}</span>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-slate-400">
          {t('products.subtitle', lang)}
        </p>
      </div>

      <!-- Product cards grid -->
      <div class="stagger-children grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {products.map((product) => (
          <ProductCard
            lang={lang}
            name={product.name}
            tagline={product.tagline}
            href={product.href}
            icon={product.icon}
            category={product.category}
            highlights={product.highlights}
            description={product.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── Trust Indicators ───────────────────────────────────── -->
  <TrustIndicators lang={lang} />

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <CTA lang={lang} />

  <!-- Footer injected into named slot -->
  <Footer slot="footer" lang={lang} />
</Layout>
