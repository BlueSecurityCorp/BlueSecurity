---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import TrustIndicators from '../components/TrustIndicators.astro';
import CTA from '../components/CTA.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import type { Locale } from '../i18n/index';
import { t } from '../i18n/ui';
import { getProductLineup } from '../data/products';
import { getCompany } from '../data/company';

const lang = 'ko' as Locale;
const products = getProductLineup(lang);
const company = getCompany(lang);
---

<Layout
  title={`${company.name} - ${company.slogan}`}
  description={company.description}
>
  <!-- Header injected into named slot -->
  <Header slot="header" lang={lang} />

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <Hero lang={lang} />

  <!-- ── Products ──────────────────────────────────────────── -->
  <section class="border-b border-slate-800 bg-navy-900 py-12" aria-labelledby="products-heading">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!-- Section header -->
      <div class="mb-8 grid gap-4 lg:grid-cols-[320px_1fr] lg:items-end">
        <p class="text-sm font-semibold uppercase tracking-widest text-blue-400">
          {t('products.eyebrow', lang)}
        </p>
        <div>
          <h2 id="products-heading" class="text-3xl font-semibold text-white md:text-4xl">
            {t('products.heading', lang)}
          </h2>
          <p class="mt-4 max-w-2xl text-slate-400">
            {t('products.subtitle', lang)}
          </p>
        </div>
      </div>

      <!-- Product cards grid -->
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        {products.map((product) => (
          <ProductCard
            lang={lang}
            name={product.name}
            tagline={product.tagline}
            href={product.href}
            icon={product.icon}
            category={product.category}
            highlights={product.highlights}
            description={product.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── Trust Indicators ───────────────────────────────────── -->
  <TrustIndicators lang={lang} />

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <CTA lang={lang} />

  <!-- Footer injected into named slot -->
  <Footer slot="footer" lang={lang} />
</Layout>
