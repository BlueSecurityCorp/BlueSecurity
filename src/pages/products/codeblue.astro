---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import type { Locale } from '../../i18n/index';
import { t } from '../../i18n/ui';
import { getProducts } from '../../data/products';

const lang = 'ko' as Locale;
const products = getProducts(lang);
const product = products.find((p) => p.id === 'codeblue')!;
---

<Layout
  title={`${product.name} | BlueSecurity`}
  description={product.description}
>
  <Header slot="header" lang={lang} />

  <!-- Hero -->
  <section class="border-b border-slate-800 bg-navy-900 pt-24 pb-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-slate-300 transition-colors">{t('products.detail.home', lang)}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a href="/products" class="hover:text-slate-300 transition-colors">{t('products.detail.products', lang)}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-blue-400">{product.name}</span>
      </nav>

      <div class="max-w-3xl">
        <!-- Left: Text -->
        <div>
          <!-- Category badge -->
          <span class="mb-3 inline-flex text-sm font-semibold uppercase tracking-widest text-blue-300">
            {product.category}
          </span>

          <h1 class="text-4xl font-semibold leading-tight text-white sm:text-5xl">
            {product.name}
          </h1>
          <p class="mt-4 text-lg font-medium text-slate-300">{product.tagline}</p>
          <p class="mt-4 text-base leading-7 text-slate-400">{product.description}</p>

          <!-- CTA buttons -->
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://codeblue.bluesecurity.online"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-500"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              {t('products.detail.start', lang)}
            </a>
            <a
              href="/contact"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-500 hover:bg-slate-900"
            >
              {t('products.detail.contact', lang)}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Highlights / Stats -->
  <section class="border-b border-slate-800 bg-navy-900 py-12">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-4 px-6 sm:grid-cols-3 lg:px-8">
      {product.highlights.map((h) => (
        <div class="rounded-lg border border-slate-800 bg-navy-900 p-6">
          <div class="text-xl font-semibold text-white">{h.value}</div>
          <div class="mt-2 text-sm text-slate-400">{h.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section class="border-b border-slate-800 bg-slate-950/40 py-12">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Feature list -->
      <div>
        <h2 class="mb-6 text-3xl font-semibold text-white">{t('products.detail.features', lang)}</h2>
        <ul class="space-y-4">
          {product.features.map((feature) => (
            <li class="flex items-start gap-4 group">
              <!-- Checkmark icon -->
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full border border-slate-700 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-slate-300 leading-relaxed">{feature}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Use case card -->
      <div class="rounded-lg border border-slate-800 bg-navy-900 p-6">
        <h3 class="mb-6 text-xl font-semibold text-white">
          이런 팀에 적합합니다
        </h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3 rounded-lg border border-slate-800 bg-slate-950/50 p-4">
            <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <div>
              <div class="text-white font-medium text-sm">DevSecOps 도입 팀</div>
              <div class="text-slate-500 text-xs mt-0.5">CI/CD 파이프라인에 보안 스캔을 자동화하고 싶은 개발팀</div>
            </div>
          </div>
          <div class="flex items-start gap-3 rounded-lg border border-slate-800 bg-slate-950/50 p-4">
            <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <div>
              <div class="text-white font-medium text-sm">컴플라이언스 대응 기업</div>
              <div class="text-slate-500 text-xs mt-0.5">ISMS-P, OWASP, CWE 기준 정기 감사가 필요한 기업</div>
            </div>
          </div>
          <div class="flex items-start gap-3 rounded-lg border border-slate-800 bg-slate-950/50 p-4">
            <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
            <div>
              <div class="text-white font-medium text-sm">소프트웨어 공급망 관리</div>
              <div class="text-slate-500 text-xs mt-0.5">오픈소스 의존성 취약점과 SBOM 자동화가 필요한 조직</div>
            </div>
          </div>
        </div>

        <!-- Standards -->
        <div class="mt-6 border-t border-slate-800 pt-6">
          <p class="text-xs text-slate-500 mb-3 uppercase tracking-wider font-medium">대응 보안 표준</p>
          <div class="flex flex-wrap gap-2">
            {['OWASP Top 10', 'CWE', 'ISMS-P', 'SBOM'].map((std) => (
              <span class="rounded-md border border-slate-800 px-2.5 py-1 text-xs font-medium text-blue-300">
                {std}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-navy-900 py-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid items-center gap-6 rounded-lg border border-slate-800 bg-slate-950/50 p-8 md:grid-cols-[1fr_auto]">
        <div>
          <h2 class="text-2xl font-semibold text-white">
            지금 바로 무료로 시작하세요
          </h2>
          <p class="mt-3 max-w-2xl text-slate-400">
            2026년 12월 31일까지 무료로 사용해 볼 수 있습니다.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="https://codeblue.bluesecurity.online"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-500"
          >
            {t('products.detail.start', lang)}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="/products"
            class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-500 hover:bg-slate-900"
          >
            {t('products.detail.others', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</Layout>
