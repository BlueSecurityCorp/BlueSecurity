---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ProductCard from '../../components/ProductCard.astro';
import TrustIndicators from '../../components/TrustIndicators.astro';
import CTA from '../../components/CTA.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import { getProductLineup } from '../../data/products';
import { getCompany } from '../../data/company';
import { t } from '../../i18n/ui';

const lang = 'en' as const;
const company = getCompany(lang);
const products = getProductLineup(lang);
---

<Layout
  title={`${company.name} - ${company.slogan}`}
  description={company.description}
  lang={lang}
>
  <!-- Header injected into named slot -->
  <Header slot="header" lang={lang} />

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <Hero lang={lang} />

  <!-- ── Products ──────────────────────────────────────────── -->
  <section class="border-b border-slate-800 bg-navy-900 py-20" aria-labelledby="products-heading">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!-- Section header -->
      <div class="mb-10 max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-blue-400">
          {t('products.eyebrow', lang)}
        </p>
        <h2
          id="products-heading"
          class="text-3xl font-semibold text-white md:text-4xl"
        >
          {t('products.heading', lang)}
          <span class="text-blue-300">{t('products.heading.accent', lang)}</span>
        </h2>
        <p class="mt-4 max-w-2xl text-slate-400">
          {t('products.subtitle', lang)}
        </p>
      </div>

      <!-- Product cards grid -->
      <div class="grid max-w-4xl grid-cols-1 gap-4 sm:grid-cols-2">
        {products.map((product) => (
          <ProductCard
            name={product.name}
            tagline={product.tagline}
            href={product.href}
            icon={product.icon}
            category={product.category}
            highlights={product.highlights}
            description={product.description}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── Trust Indicators ───────────────────────────────────── -->
  <TrustIndicators lang={lang} />

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <CTA lang={lang} />

  <!-- Footer injected into named slot -->
  <Footer slot="footer" lang={lang} />
</Layout>
