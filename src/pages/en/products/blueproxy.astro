---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getProducts } from '../../../data/products';
import { t } from '../../../i18n/ui';
import { localePath } from '../../../i18n/index';

const lang = 'en' as const;
const products = getProducts(lang);
const product = products.find((p) => p.id === 'blueproxy')!;

const platforms = [
  {
    name: 'Android',
    description: 'APK traffic analysis and SSL pinning bypass support',
    color: 'from-green-600/20 to-green-800/10',
    border: 'border-green-500/30',
    textColor: 'text-green-400',
    // Android robot icon
    svgPath: 'M6.6 10.8c0-.662.538-1.2 1.2-1.2s1.2.538 1.2 1.2-.538 1.2-1.2 1.2-1.2-.538-1.2-1.2zm8.4 0c0-.662.538-1.2 1.2-1.2s1.2.538 1.2 1.2-.538 1.2-1.2 1.2-1.2-.538-1.2-1.2zM12 2a7 7 0 00-5.957 3.332l-.008.013L4.3 4.3a.75.75 0 00-.6 1.2L5.15 7.1A6.963 6.963 0 005 9v1h.006A7 7 0 0012 17a7 7 0 006.994-7H19V9a6.963 6.963 0 00-.15-1.9l1.45-1.6a.75.75 0 00-.6-1.2l-1.735 1.046A7 7 0 0012 2zm0 1.5a5.5 5.5 0 110 11 5.5 5.5 0 010-11z',
  },
  {
    name: 'iOS',
    description: 'iPhone/iPad app traffic intercept and certificate analysis',
    color: 'from-slate-600/20 to-slate-800/10',
    border: 'border-slate-500/30',
    textColor: 'text-slate-300',
    // Apple-like icon path
    svgPath: 'M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z',
  },
  {
    name: 'Windows',
    description: 'Desktop application TCP traffic monitoring and modification',
    color: 'from-blue-600/20 to-blue-800/10',
    border: 'border-blue-500/30',
    textColor: 'text-blue-400',
    // Windows logo-like icon
    svgPath: 'M3 5.557L10.5 4.5v7H3V5.557zM21 3l-9 1.243V11.5h9V3zM3 12.5h7.5v7.057L3 18.443V12.5zM12 12.5H21V21l-9-1.243V12.5z',
  },
];
---

<Layout
  title={`${product.name} | BlueSecurity`}
  description={product.description}
  lang={lang}
>
  <Header slot="header" lang={lang} />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-grid">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-900/95 to-navy-900 pointer-events-none"></div>
    <!-- Ambient glows -->
    <div class="absolute top-0 left-1/4 w-[600px] h-[500px] bg-cyan-700/8 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-0 right-1/3 w-[500px] h-[400px] bg-blue-700/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-slate-500 mb-10">
        <a href={localePath('/', lang)} class="hover:text-slate-300 transition-colors">{t('products.detail.home', lang)}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a href={localePath('/products', lang)} class="hover:text-slate-300 transition-colors">{t('products.detail.products', lang)}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-blue-400">{product.name}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text -->
        <div class="animate-fade-in-up">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 text-sm font-medium mb-6">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 8 8">
              <circle cx="4" cy="4" r="3" />
            </svg>
            {product.category}
          </span>

          <h1 class="text-5xl sm:text-6xl font-bold mb-4">
            <span class="text-gradient">{product.name}</span>
          </h1>
          <p class="text-xl text-slate-300 font-medium mb-6">{product.tagline}</p>
          <p class="text-slate-400 leading-relaxed text-lg mb-10">{product.description}</p>

          <!-- Warning badge -->
          <div class="flex items-start gap-3 p-4 rounded-xl bg-amber-900/20 border border-amber-700/30 text-amber-300 text-sm mb-8">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            This tool is for authorized penetration testing only. Use on unauthorized systems is strictly prohibited.
          </div>

          <div class="flex flex-wrap gap-4">
            <a
              href="https://github.com/BlueSecurityCorp/blueproxy"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-all duration-200 glow-blue"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              View on GitHub
            </a>
            <a
              href={localePath('/products', lang)}
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg border border-blue-700/60 hover:border-blue-500 text-slate-300 hover:text-white font-medium transition-all duration-200"
            >
              {t('products.detail.others', lang)}
            </a>
          </div>
        </div>

        <!-- Right: Network/signal icon -->
        <div class="flex items-center justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute inset-0 rounded-full border border-cyan-500/15 scale-125"></div>
            <div class="absolute inset-0 rounded-full border border-cyan-500/8 scale-150"></div>
            <div class="relative w-48 h-48 rounded-3xl bg-gradient-to-br from-cyan-900/40 to-navy-800/80 border border-cyan-500/30 flex items-center justify-center glow-cyan">
              <!-- Network/signal SVG -->
              <svg class="w-24 h-24 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />
              </svg>
            </div>
            <div class="absolute -bottom-3 -right-3 px-3 py-1.5 rounded-lg bg-cyan-500/20 border border-cyan-500/40 text-cyan-400 text-xs font-bold">
              TCP
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Highlights -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 stagger-children">
      {product.highlights.map((h) => (
        <div class="card-hover relative rounded-2xl border border-blue-800/50 bg-navy-800/60 p-8 text-center overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/40 to-transparent"></div>
          <div class="text-5xl font-bold text-gradient mb-3">{h.value}</div>
          <div class="text-slate-400 font-medium">{h.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Supported Platforms -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-3">Supported Platforms</h2>
      <div class="w-12 h-1 bg-gradient-to-r from-cyan-500 to-blue-400 rounded-full mx-auto mb-4"></div>
      <p class="text-slate-400 max-w-xl mx-auto">
        The same level of TCP traffic analysis and manipulation is available across Android, iOS, and Windows.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
      {platforms.map((platform) => (
        <div class={`card-hover relative rounded-2xl border ${platform.border} bg-gradient-to-b ${platform.color} bg-navy-800/60 p-8 overflow-hidden`}>
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-current to-transparent opacity-20"></div>

          <!-- Platform icon -->
          <div class={`w-14 h-14 rounded-xl bg-navy-900/60 border ${platform.border} flex items-center justify-center mb-5`}>
            <svg class={`w-7 h-7 ${platform.textColor}`} viewBox="0 0 24 24" fill="currentColor">
              <path d={platform.svgPath} />
            </svg>
          </div>

          <h3 class={`text-xl font-bold mb-2 ${platform.textColor}`}>{platform.name}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{platform.description}</p>

          <!-- Supported badge -->
          <div class={`mt-4 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border ${platform.border} ${platform.textColor} bg-navy-900/40`}>
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 8 8">
              <circle cx="4" cy="4" r="3" />
            </svg>
            Supported
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Feature list -->
      <div>
        <h2 class="text-3xl font-bold text-white mb-2">{t('products.detail.features', lang)}</h2>
        <div class="w-12 h-1 bg-gradient-to-r from-cyan-500 to-blue-400 rounded-full mb-8"></div>
        <ul class="space-y-4">
          {product.features.map((feature) => (
            <li class="flex items-start gap-4 group">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-cyan-600/20 border border-cyan-500/40 flex items-center justify-center group-hover:bg-cyan-600/40 transition-colors duration-200">
                <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-slate-300 leading-relaxed">{feature}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Technical details card -->
      <div class="rounded-2xl border border-cyan-800/40 bg-navy-800/50 p-8">
        <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
          <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Core Technical Specifications
        </h3>

        <div class="space-y-3">
          {[
            { label: 'Protocol', value: 'TCP (Layer 4)', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
            { label: 'Intercept Method', value: 'MITM + SSL/TLS Pinning Bypass', icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z' },
            { label: 'Packet Handling', value: 'Policy-Based Modification + Codec Chain', icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4' },
            { label: 'Logging', value: 'Full Session Audit Log + Replay', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
            { label: 'License', value: 'Authorized Penetration Testing Only', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
          ].map((spec) => (
            <div class="flex items-center gap-4 p-3.5 rounded-xl bg-navy-900/50 border border-cyan-900/30">
              <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-cyan-600/15 border border-cyan-500/25 flex items-center justify-center">
                <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={spec.icon} />
                </svg>
              </div>
              <div class="flex-1 flex items-center justify-between gap-2 flex-wrap">
                <span class="text-slate-500 text-sm">{spec.label}</span>
                <span class="text-slate-200 text-sm font-medium">{spec.value}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 pt-6 border-t border-cyan-900/30">
          <p class="text-xs text-slate-500 mb-3 uppercase tracking-wider font-medium">Use Cases</p>
          <div class="flex flex-wrap gap-2">
            {['Penetration Testing', 'API Security Analysis', 'App Vulnerability Assessment', 'Traffic Forensics'].map((tag) => (
              <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-cyan-900/30 text-cyan-300 border border-cyan-800/50">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="relative rounded-2xl overflow-hidden border border-cyan-700/30">
      <div class="absolute inset-0 bg-gradient-to-r from-cyan-900/40 via-navy-800/80 to-blue-900/50"></div>
      <div class="absolute inset-0 bg-grid opacity-30"></div>
      <div class="relative px-8 py-12 md:px-16 md:py-16 flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
            BlueProxy is Open Source
          </h2>
          <p class="text-slate-400 max-w-lg">
            Check out the source code on GitHub. Report issues or contribute to help improve the project.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
          <a
            href="https://github.com/BlueSecurityCorp/blueproxy"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-all duration-200 whitespace-nowrap"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a
            href={localePath('/products', lang)}
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-lg border border-white/20 hover:border-white/40 text-slate-300 hover:text-white font-medium transition-all duration-200 whitespace-nowrap"
          >
            {t('products.detail.others', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</Layout>
