---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { getProductLineup } from '../../../data/products';
import { t } from '../../../i18n/ui';
import { localePath } from '../../../i18n/index';

const lang = 'en' as const;
const products = getProductLineup(lang);
---

<Layout
  title={t('products.page.title', lang)}
  description={t('products.page.meta', lang)}
  lang={lang}
>
  <Header slot="header" lang={lang} />

  <!-- Hero -->
  <section class="border-b border-slate-800 bg-navy-900 pt-24 pb-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-blue-300">
        {t('products.page.eyebrow', lang)}
      </p>
      <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl">
        {t('products.page.heading', lang)}
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-slate-400">
        {t('products.page.subtitle', lang)}
      </p>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="border-b border-slate-800 bg-navy-900 py-12">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-4 px-6 lg:grid-cols-2 lg:px-8">
      {products.map((product) => (
        <ProductCard
          lang={lang}
          name={product.name}
          tagline={product.tagline}
          href={product.href}
          icon={product.icon}
          category={product.category}
          highlights={product.highlights}
          description={product.description}
        />
      ))}
    </div>
  </section>

  <!-- Why BlueSecurity banner -->
  <section class="bg-navy-900 py-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid items-center gap-6 rounded-lg border border-slate-800 bg-slate-950/50 p-8 md:grid-cols-[1fr_auto]">
        <div>
          <h2 class="text-2xl font-semibold text-white">
          {t('products.page.bundle.heading', lang)}
          </h2>
          <p class="mt-3 max-w-2xl text-slate-400">
            {t('products.page.bundle.description', lang)}
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href={localePath('/contact', lang)}
            class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-500"
          >
            {t('products.page.bundle.cta', lang)}
          </a>
          <a
            href={localePath('/pricing', lang)}
            class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-500 hover:bg-slate-900"
          >
            {t('products.page.pricing', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</Layout>
