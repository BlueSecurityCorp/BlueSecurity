---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getProducts } from '../../../data/products';
import { t } from '../../../i18n/ui';
import { localePath } from '../../../i18n/index';

const lang = 'en' as const;
const products = getProducts(lang);
const product = products.find((p) => p.id === 'bluephalanx')!;

const pipeline = [
  {
    step: 1,
    name: 'EMBER2024 ML',
    label: 'ML Classification Model',
    description: 'Machine learning-based initial threat classification and anomaly scoring',
    color: 'from-purple-600/30 to-purple-800/20',
    border: 'border-purple-500/40',
    badge: 'bg-purple-500/20 text-purple-300 border-purple-500/30',
  },
  {
    step: 2,
    name: 'ClamAV',
    label: 'Signature-Based Detection',
    description: 'Scan against known malware signature database',
    color: 'from-blue-600/30 to-blue-800/20',
    border: 'border-blue-500/40',
    badge: 'bg-blue-500/20 text-blue-300 border-blue-500/30',
  },
  {
    step: 3,
    name: 'YARA-X',
    label: 'Pattern Matching',
    description: 'YARA ruleset-based malware pattern and IoC matching',
    color: 'from-cyan-600/30 to-cyan-800/20',
    border: 'border-cyan-500/40',
    badge: 'bg-cyan-500/20 text-cyan-300 border-cyan-500/30',
  },
  {
    step: 4,
    name: 'CAPE Sandbox',
    label: 'Dynamic Behavior Analysis',
    description: 'Execute in isolated environment to analyze behavior patterns and API calls',
    color: 'from-orange-600/30 to-orange-800/20',
    border: 'border-orange-500/40',
    badge: 'bg-orange-500/20 text-orange-300 border-orange-500/30',
  },
  {
    step: 5,
    name: 'Suricata',
    label: 'Network Traffic Analysis',
    description: 'Detect C2 communications and anomalous traffic during malware execution',
    color: 'from-green-600/30 to-green-800/20',
    border: 'border-green-500/40',
    badge: 'bg-green-500/20 text-green-300 border-green-500/30',
  },
  {
    step: 6,
    name: 'Volatility 3',
    label: 'Memory Forensics',
    description: 'Analyze runtime memory dumps to detect hidden processes and injection',
    color: 'from-red-600/30 to-red-800/20',
    border: 'border-red-500/40',
    badge: 'bg-red-500/20 text-red-300 border-red-500/30',
  },
];
---

<Layout
  title={`${product.name} | BlueSecurity`}
  description={product.description}
  lang={lang}
>
  <Header slot="header" lang={lang} />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-grid">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-900/95 to-navy-900 pointer-events-none"></div>
    <!-- Ambient glows -->
    <div class="absolute top-0 left-1/3 w-[600px] h-[500px] bg-purple-700/8 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-0 right-1/4 w-[500px] h-[400px] bg-blue-700/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-slate-500 mb-10">
        <a href={localePath('/', lang)} class="hover:text-slate-300 transition-colors">{t('products.detail.home', lang)}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a href={localePath('/products', lang)} class="hover:text-slate-300 transition-colors">{t('products.detail.products', lang)}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-blue-400">{product.name}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text -->
        <div class="animate-fade-in-up">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 text-sm font-medium mb-6">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 8 8">
              <circle cx="4" cy="4" r="3" />
            </svg>
            {product.category}
          </span>

          <h1 class="text-5xl sm:text-6xl font-bold mb-4">
            <span class="text-gradient">{product.name}</span>
          </h1>
          <p class="text-xl text-slate-300 font-medium mb-6">{product.tagline}</p>
          <p class="text-slate-400 leading-relaxed text-lg mb-10">{product.description}</p>

          <div class="flex flex-wrap gap-4">
            <a
              href={localePath('/contact', lang)}
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-all duration-200 glow-blue"
            >
              {t('products.detail.contact', lang)}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
            <a
              href={localePath('/products', lang)}
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg border border-blue-700/60 hover:border-blue-500 text-slate-300 hover:text-white font-medium transition-all duration-200"
            >
              {t('products.detail.others', lang)}
            </a>
          </div>
        </div>

        <!-- Right: Shield icon display -->
        <div class="flex items-center justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute inset-0 rounded-full border border-blue-500/15 scale-125"></div>
            <div class="absolute inset-0 rounded-full border border-blue-500/8 scale-150"></div>
            <div class="relative w-48 h-48 rounded-3xl bg-gradient-to-br from-blue-900/60 to-navy-800/80 border border-blue-500/30 flex items-center justify-center glow-blue">
              <!-- Shield SVG -->
              <svg class="w-24 h-24 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div class="absolute -bottom-3 -right-3 px-3 py-1.5 rounded-lg bg-purple-500/20 border border-purple-500/40 text-purple-400 text-xs font-bold">
              6-Layer
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Highlights -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 stagger-children">
      {product.highlights.map((h) => (
        <div class="card-hover relative rounded-2xl border border-blue-800/50 bg-navy-800/60 p-8 text-center overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500/40 to-transparent"></div>
          <div class="text-5xl font-bold text-gradient mb-3">{h.value}</div>
          <div class="text-slate-400 font-medium">{h.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 6-Layer Detection Pipeline -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-3">6-Layer Detection Pipeline</h2>
      <div class="w-12 h-1 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full mx-auto mb-4"></div>
      <p class="text-slate-400 max-w-xl mx-auto">
        Beyond the limits of a single engine — 6 specialized analysis layers sequentially identify threats.
        Each layer compensates for what previous layers may have missed.
      </p>
    </div>

    <div class="max-w-3xl mx-auto">
      <!-- Input indicator -->
      <div class="flex justify-center mb-4">
        <div class="px-6 py-3 rounded-xl bg-navy-800/80 border border-slate-700/60 text-slate-400 text-sm font-medium flex items-center gap-2">
          <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          File / Sample Input
        </div>
      </div>

      <!-- Down arrow -->
      <div class="flex justify-center mb-2">
        <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>

      <!-- Pipeline steps -->
      <div class="space-y-2">
        {pipeline.map((layer, idx) => (
          <div>
            <div class={`card-hover relative rounded-xl border ${layer.border} bg-gradient-to-r ${layer.color} bg-navy-800/60 p-5 overflow-hidden`}>
              <div class="flex items-center gap-5">
                <!-- Step number -->
                <div class={`flex-shrink-0 w-10 h-10 rounded-lg border ${layer.badge.replace('text-', 'border-').split(' ').pop()} bg-navy-900/60 flex items-center justify-center`}>
                  <span class={`text-sm font-bold ${layer.badge.split(' ')[1]}`}>{layer.step}</span>
                </div>

                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 flex-wrap">
                    <span class="text-white font-bold text-base">{layer.name}</span>
                    <span class={`px-2 py-0.5 rounded text-xs font-medium border ${layer.badge}`}>
                      {layer.label}
                    </span>
                  </div>
                  <p class="text-slate-400 text-sm mt-1">{layer.description}</p>
                </div>

                <!-- Arrow icon -->
                <svg class="w-5 h-5 text-slate-600 flex-shrink-0 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>

            <!-- Connector arrow between steps -->
            {idx < pipeline.length - 1 && (
              <div class="flex justify-center py-1">
                <svg class="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Output indicator -->
      <div class="flex justify-center mt-2 mb-4">
        <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
      <div class="flex justify-center">
        <div class="px-6 py-3 rounded-xl bg-blue-600/20 border border-blue-500/40 text-blue-300 text-sm font-medium flex items-center gap-2">
          <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Threat Intelligence Report + STIX 2.1 Output
        </div>
      </div>
    </div>
  </section>

  <!-- Features + Deployment modes -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Feature list -->
      <div>
        <h2 class="text-3xl font-bold text-white mb-2">{t('products.detail.features', lang)}</h2>
        <div class="w-12 h-1 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full mb-8"></div>
        <ul class="space-y-4">
          {product.features.map((feature) => (
            <li class="flex items-start gap-4 group">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-blue-600/20 border border-blue-500/40 flex items-center justify-center group-hover:bg-blue-600/40 transition-colors duration-200">
                <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-slate-300 leading-relaxed">{feature}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Deployment modes -->
      <div class="rounded-2xl border border-blue-800/40 bg-navy-800/50 p-8">
        <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
          <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
          Flexible Deployment Options
        </h3>
        <div class="space-y-4">
          {[
            {
              mode: 'SaaS',
              desc: 'Instantly available cloud deployment — get started without managing infrastructure',
              icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
            },
            {
              mode: 'On-Premise',
              desc: 'Install within your own data center for complete data sovereignty',
              icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
            },
            {
              mode: 'Air-Gap',
              desc: 'Fully isolated network environment support — no external connectivity required',
              icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636',
            },
          ].map((d) => (
            <div class="flex items-start gap-3 p-4 rounded-xl bg-navy-900/50 border border-blue-900/40">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={d.icon} />
              </svg>
              <div>
                <div class="text-white font-medium text-sm">{d.mode}</div>
                <div class="text-slate-500 text-xs mt-0.5">{d.desc}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 pt-6 border-t border-blue-900/40">
          <p class="text-xs text-slate-500 mb-3 uppercase tracking-wider font-medium">Integration Standards</p>
          <div class="flex flex-wrap gap-2">
            {['MISP', 'STIX 2.1', 'TAXII 2.1', 'MITRE ATT&CK'].map((std) => (
              <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-blue-900/40 text-blue-300 border border-blue-800/50">
                {std}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="relative rounded-2xl overflow-hidden border border-blue-700/30">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-900/60 via-navy-800/80 to-purple-900/30"></div>
      <div class="absolute inset-0 bg-grid opacity-30"></div>
      <div class="relative px-8 py-12 md:px-16 md:py-16 flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
            Inquire About BluePhalanx
          </h2>
          <p class="text-slate-400 max-w-lg">
            We'll guide you to the optimal deployment method and pricing for your security environment.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
          <a
            href={localePath('/contact', lang)}
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-all duration-200 whitespace-nowrap"
          >
            {t('products.detail.contact', lang)}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href={localePath('/products', lang)}
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-lg border border-white/20 hover:border-white/40 text-slate-300 hover:text-white font-medium transition-all duration-200 whitespace-nowrap"
          >
            {t('products.detail.others', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</Layout>
