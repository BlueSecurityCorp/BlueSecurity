---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.tsx';
import { t } from '../../i18n/ui';

const lang = 'en' as const;
---

<Layout
  title={t('contact.title', lang)}
  description={t('contact.meta', lang)}
  lang={lang}
>

  <Header slot="header" lang={lang} />

  <!-- ─────────────────────── PAGE WRAPPER ─────────────────────── -->
  <div class="relative min-h-screen overflow-hidden bg-navy-900">

    <!-- Subtle grid background -->
    <div class="pointer-events-none absolute inset-0 bg-grid opacity-50" />

    <!-- Top radial glow -->
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-blue-600/10 blur-[120px]"
      aria-hidden="true"
    />

    <!-- ─────────────────────── HERO SECTION ─────────────────────── -->
    <section class="relative px-4 pb-12 pt-24 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">

        <!-- Eyebrow badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-blue-800/60 bg-blue-900/30 px-4 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-blue-400 shadow-[0_0_6px_#60a5fa]" aria-hidden="true" />
          <span class="text-xs font-medium tracking-wider text-blue-300 uppercase">Contact Us</span>
        </div>

        <h1 class="mb-5 text-4xl font-bold tracking-tight text-slate-100 sm:text-5xl lg:text-6xl">
          {t('contact.heading', lang)}
        </h1>
        <p class="text-base leading-relaxed text-slate-400 sm:text-lg">
          {t('contact.subtitle', lang)}
        </p>
      </div>
    </section>

    <!-- ─────────────────────── MAIN CONTENT ─────────────────────── -->
    <section class="relative px-4 pb-24 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">

        <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:gap-16">

          <!-- ────────────── LEFT: Contact info ────────────── -->
          <aside class="lg:col-span-2">

            <!-- Sticky container on desktop -->
            <div class="lg:sticky lg:top-24 flex flex-col gap-8">

              <!-- Email card -->
              <div class="rounded-2xl border border-blue-800/40 bg-navy-800/60 p-6 shadow-lg backdrop-blur-sm">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">
                  {t('contact.email.heading', lang)}
                </h2>

                <a
                  href="mailto:blue@bluesecurity.online"
                  class="group flex items-center gap-3 rounded-xl border border-slate-700/60 bg-slate-800/50 px-4 py-3.5 transition-all duration-200 hover:border-blue-600/60 hover:bg-slate-800"
                >
                  <!-- Mail icon -->
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-blue-600/15 text-blue-400 group-hover:bg-blue-600/25 transition-colors">
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                      />
                    </svg>
                  </span>
                  <div class="min-w-0">
                    <p class="truncate text-sm font-medium text-slate-200 group-hover:text-blue-300 transition-colors">
                      blue@bluesecurity.online
                    </p>
                    <p class="text-xs text-slate-500">{t('contact.email.button', lang)}</p>
                  </div>
                </a>
              </div>

              <!-- Response time card -->
              <div class="rounded-2xl border border-blue-800/40 bg-navy-800/60 p-6 shadow-lg backdrop-blur-sm">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">
                  {t('contact.response.heading', lang)}
                </h2>

                <div class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400">
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                  </span>
                  <div>
                    <p class="text-sm font-medium text-slate-200">{t('contact.response.time', lang)}</p>
                    <p class="mt-1 text-xs leading-relaxed text-slate-500">
                      {t('contact.response.detail', lang)}
                    </p>
                  </div>
                </div>
              </div>

              <!-- Inquiry types card -->
              <div class="rounded-2xl border border-blue-800/40 bg-navy-800/60 p-6 shadow-lg backdrop-blur-sm">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">
                  {t('contact.type.heading', lang)}
                </h2>

                <ul class="flex flex-col gap-2.5">
                  {[
                    { label: t('form.type.product', lang), desc: 'CodeBlue, BluePhalanx, BlueProxy' },
                    { label: t('form.type.quote', lang), desc: 'Custom quotes for team & enterprise plans' },
                    { label: t('form.type.support', lang), desc: 'Technical issues after deployment' },
                    { label: t('form.type.other', lang), desc: 'Partnership, media, general inquiries' },
                  ].map(({ label, desc }) => (
                    <li class="flex items-start gap-2.5">
                      <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-blue-500" aria-hidden="true" />
                      <span>
                        <span class="text-sm font-medium text-slate-300">{label}</span>
                        <span class="ml-1 text-xs text-slate-500">— {desc}</span>
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

            </div>
          </aside>

          <!-- ────────────── RIGHT: Contact form ────────────── -->
          <div class="lg:col-span-3">
            <div class="rounded-2xl border border-blue-800/40 bg-navy-800/60 p-6 shadow-xl backdrop-blur-sm sm:p-8">

              <div class="mb-7">
                <h2 class="text-xl font-semibold text-slate-100">
                  {t('contact.form.heading', lang)}
                </h2>
                <p class="mt-1.5 text-sm text-slate-500">
                  <span class="text-red-400">*</span> {t('contact.form.required', lang)}
                </p>
              </div>

              <!-- React island: hydrates when scrolled into view -->
              <ContactForm client:visible lang={lang} />

            </div>
          </div>

        </div>
      </div>
    </section>

  </div>

  <Footer slot="footer" lang={lang} />

</Layout>
