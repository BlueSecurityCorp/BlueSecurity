---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PricingTable from '../../components/PricingTable.astro';
import { getFaq } from '../../data/pricing';
import { t } from '../../i18n/ui';
import { localePath } from '../../i18n/index';

const lang = 'en' as const;
const faq = getFaq(lang);
---

<Layout
  title={t('pricing.title', lang)}
  description={t('pricing.meta', lang)}
  lang={lang}
>
  <Header slot="header" lang={lang} />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-grid pt-32 pb-16">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-b from-blue-950/30 via-transparent to-transparent"
    >
    </div>
    <div class="relative mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm font-semibold tracking-[0.2em] text-blue-400 uppercase">
        Pricing
      </p>
      <h1 class="mb-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        {t('pricing.heading', lang)}
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-slate-400 leading-relaxed">
        {t('pricing.subtitle', lang)}
      </p>

      <!-- Annual discount badge -->
      <div
        class="mt-6 inline-flex items-center gap-2 rounded-full border border-blue-800/60 bg-blue-900/30 px-4 py-1.5"
      >
        <svg
          class="h-4 w-4 text-cyan-400"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
            clip-rule="evenodd"></path>
        </svg>
        <span class="text-sm font-medium text-slate-300">
          {t('pricing.annual', lang)}
        </span>
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <PricingTable lang={lang} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 border-t border-blue-900/30 bg-navy-800/40">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="mb-2 text-sm font-semibold tracking-[0.2em] text-blue-400 uppercase">FAQ</p>
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">{t('pricing.faq.heading', lang)}</h2>
      </div>

      <div class="space-y-3">
        {
          faq.map((item) => (
            <details class="group rounded-xl border border-blue-900/50 bg-navy-800 overflow-hidden">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left select-none hover:bg-blue-900/20 transition-colors duration-150">
                <span class="font-semibold text-white text-sm sm:text-base">
                  {item.question}
                </span>
                {/* Chevron icon — rotates when open via CSS */}
                <svg
                  class="h-5 w-5 shrink-0 text-blue-400 transition-transform duration-200 group-open:rotate-180"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              <div class="px-6 pb-5">
                <div class="h-px w-full bg-blue-900/40 mb-4" />
                <p class="text-sm text-slate-400 leading-relaxed">{item.answer}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="relative overflow-hidden rounded-2xl border border-blue-700/40 bg-navy-700 p-10 text-center glow-blue"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-br from-blue-700/10 via-transparent to-cyan-700/10"
        >
        </div>
        <div class="relative">
          <h2 class="mb-3 text-2xl font-extrabold text-white sm:text-3xl">
            {t('pricing.custom.heading', lang)}
          </h2>
          <p class="mb-6 text-slate-400 max-w-xl mx-auto">
            {t('pricing.custom.description', lang)}
          </p>
          <a
            href={localePath('/contact', lang)}
            class="inline-block rounded-xl bg-blue-600 px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-900/50 transition-all duration-200 hover:bg-blue-500"
          >
            {t('pricing.custom.cta', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</Layout>
