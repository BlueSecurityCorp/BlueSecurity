---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.tsx';
import type { Locale } from '../i18n/index';
import { t } from '../i18n/ui';

const lang = 'ko' as Locale;
const pageTitle = t('contact.title', lang);
const pageDescription = t('contact.meta', lang);
---

<Layout title={pageTitle} description={pageDescription}>

  <Header slot="header" lang={lang} />

  <!-- ─────────────────────── PAGE WRAPPER ─────────────────────── -->
  <div class="bg-navy-900">

    <!-- ─────────────────────── HERO SECTION ─────────────────────── -->
    <section class="border-b border-slate-800 px-6 pt-28 pb-14 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue-300">Contact Us</p>

        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl">
          {t('contact.heading', lang)}
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-slate-400">
          {t('contact.subtitle', lang)}
        </p>
      </div>
    </section>

    <!-- ─────────────────────── MAIN CONTENT ─────────────────────── -->
    <section class="px-6 py-16 lg:px-8">
      <div class="mx-auto max-w-7xl">

        <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:gap-16">

          <!-- ────────────── LEFT: Contact info ────────────── -->
          <aside class="lg:col-span-2">

            <!-- Sticky container on desktop -->
            <div class="lg:sticky lg:top-24 flex flex-col gap-8">

              <!-- Email card -->
              <div class="rounded-lg border border-slate-800 bg-navy-900 p-6">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">
                  {t('contact.email.heading', lang)}
                </h2>

                <a
                  href="mailto:blue@bluesecurity.online"
                  class="group flex items-center gap-3 rounded-lg border border-slate-800 bg-slate-950/50 px-4 py-3.5 transition-colors duration-200 hover:border-slate-600"
                >
                  <!-- Mail icon -->
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-slate-800 text-blue-300">
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                      />
                    </svg>
                  </span>
                  <div class="min-w-0">
                    <p class="truncate text-sm font-medium text-slate-200 group-hover:text-blue-300 transition-colors">
                      blue@bluesecurity.online
                    </p>
                    <p class="text-xs text-slate-500">{t('contact.email.button', lang)}</p>
                  </div>
                </a>
              </div>

              <!-- Response time card -->
              <div class="rounded-lg border border-slate-800 bg-navy-900 p-6">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">
                  {t('contact.response.heading', lang)}
                </h2>

                <div class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-slate-800 text-blue-300">
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                  </span>
                  <div>
                    <p class="text-sm font-medium text-slate-200">{t('contact.response.time', lang)}</p>
                    <p class="mt-1 text-xs leading-relaxed text-slate-500">
                      {t('contact.response.detail', lang)}
                    </p>
                  </div>
                </div>
              </div>

              <!-- Inquiry types card -->
              <div class="rounded-lg border border-slate-800 bg-navy-900 p-6">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">
                  {t('contact.type.heading', lang)}
                </h2>

                <ul class="flex flex-col gap-2.5">
                  {[
                    { label: '제품 문의', desc: 'CodeBlue 및 보안 컨설팅 관련' },
                    { label: '견적 요청', desc: '팀·기업 플랜 맞춤 견적 산정' },
                    { label: '기술 지원', desc: '도입 후 기술적 문제 해결' },
                    { label: '기타', desc: '파트너십, 미디어, 일반 문의' },
                  ].map(({ label, desc }) => (
                    <li class="flex items-start gap-2.5">
                      <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-blue-500" aria-hidden="true" />
                      <span>
                        <span class="text-sm font-medium text-slate-300">{label}</span>
                        <span class="ml-1 text-xs text-slate-500">— {desc}</span>
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

            </div>
          </aside>

          <!-- ────────────── RIGHT: Contact form ────────────── -->
          <div class="lg:col-span-3">
            <div class="rounded-lg border border-slate-800 bg-navy-900 p-6 sm:p-8">

              <div class="mb-7">
                <h2 class="text-xl font-semibold text-slate-100">
                  {t('contact.form.heading', lang)}
                </h2>
                <p class="mt-1.5 text-sm text-slate-500">
                  <span class="text-red-400">*</span> {t('contact.form.required', lang)}
                </p>
              </div>

              <!-- React island: hydrates when scrolled into view -->
              <ContactForm client:visible lang={lang} />

            </div>
          </div>

        </div>
      </div>
    </section>

  </div>

  <Footer slot="footer" lang={lang} />

</Layout>
