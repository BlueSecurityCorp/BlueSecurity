---
import { company } from '../data/company';
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-grid"
  aria-label="히어로 섹션"
>
  <!-- Background: glowing orbs -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
  >
    <!-- Primary orb top-left -->
    <div
      class="absolute -left-40 -top-40 h-96 w-96 rounded-full bg-blue-600/20 blur-3xl"
    ></div>
    <!-- Secondary orb bottom-right -->
    <div
      class="absolute -bottom-40 -right-40 h-[32rem] w-[32rem] rounded-full bg-cyan-500/15 blur-3xl"
    ></div>
    <!-- Subtle center glow -->
    <div
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-blue-900/30 blur-3xl"
    ></div>
  </div>

  <!-- Radial vignette overlay -->
  <div
    class="pointer-events-none absolute inset-0 bg-radial-gradient"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 80% 60% at 50% 0%, transparent 40%, var(--color-navy-900) 100%);"
  ></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 py-24 text-center">

    <!-- Security badge -->
    <div class="animate-fade-in-up mb-8 inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-950/60 px-4 py-2 text-sm text-blue-300 backdrop-blur-sm">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-cyan-400"></span>
      </span>
      대한민국 중소기업 보안의 표준
    </div>

    <!-- Main headline -->
    <h1
      class="animate-fade-in-up mb-6 text-6xl font-black leading-tight tracking-tight md:text-7xl lg:text-8xl"
      style="animation-delay: 0.1s;"
    >
      <span class="text-gradient">{company.slogan}</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="animate-fade-in-up mx-auto mb-4 max-w-2xl text-xl leading-relaxed text-slate-300 md:text-2xl"
      style="animation-delay: 0.2s;"
    >
      {company.description}
    </p>
    <p
      class="animate-fade-in-up mx-auto mb-12 max-w-xl text-base leading-relaxed text-slate-400"
      style="animation-delay: 0.3s;"
    >
      {company.mission}
    </p>

    <!-- CTA buttons -->
    <div
      class="animate-fade-in-up flex flex-col items-center justify-center gap-4 sm:flex-row"
      style="animation-delay: 0.4s;"
    >
      <a
        href="https://codeblue.bluesecurity.online"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative inline-flex items-center gap-2 overflow-hidden rounded-xl bg-blue-600 px-8 py-4 text-base font-semibold text-white shadow-lg transition-all duration-300 hover:bg-blue-500 hover:shadow-blue-500/30 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-navy-900"
      >
        <!-- Shimmer effect -->
        <span
          class="pointer-events-none absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/10 to-transparent transition-transform duration-700 group-hover:translate-x-full"
          aria-hidden="true"
        ></span>
        <!-- Code bracket icon -->
        <svg
          class="h-5 w-5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="16 18 22 12 16 6" />
          <polyline points="8 6 2 12 8 18" />
        </svg>
        무료로 시작하기
        <svg
          class="h-4 w-4 shrink-0 transition-transform duration-200 group-hover:translate-x-1"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>

      <a
        href="/contact"
        class="group inline-flex items-center gap-2 rounded-xl border border-slate-600 bg-navy-800/80 px-8 py-4 text-base font-semibold text-slate-200 backdrop-blur-sm transition-all duration-300 hover:border-blue-500/60 hover:bg-navy-700/80 hover:text-white focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-navy-900"
      >
        <!-- Chat icon -->
        <svg
          class="h-5 w-5 shrink-0 text-slate-400 transition-colors duration-200 group-hover:text-cyan-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
        문의하기
      </a>
    </div>

    <!-- Visual element: abstract security diagram -->
    <div
      class="animate-fade-in-up pointer-events-none relative mx-auto mt-20 max-w-lg select-none"
      style="animation-delay: 0.6s;"
      aria-hidden="true"
    >
      <!-- Outer ring -->
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <div class="h-64 w-64 rounded-full border border-blue-500/10 md:h-80 md:w-80"></div>
        <div class="absolute inset-4 rounded-full border border-cyan-500/10"></div>
        <div class="absolute inset-8 rounded-full border border-blue-400/10"></div>
      </div>

      <!-- Central shield -->
      <div class="relative flex items-center justify-center py-8">
        <div class="relative flex h-28 w-28 items-center justify-center rounded-2xl border border-blue-500/30 bg-navy-800/80 shadow-2xl backdrop-blur-sm glow-blue">
          <svg
            class="h-14 w-14 text-blue-400"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            <path d="m9 12 2 2 4-4" />
          </svg>
        </div>

        <!-- Orbiting nodes -->
        <div class="absolute" style="animation: orbit 8s linear infinite;">
          <div class="relative h-72 w-72 md:h-96 md:w-96">
            <!-- Node: top -->
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 flex h-6 w-6 items-center justify-center rounded-full bg-blue-600/80 text-[10px] text-blue-100 shadow-lg shadow-blue-600/40">
              <svg viewBox="0 0 24 24" class="h-3 w-3" fill="currentColor"><circle cx="12" cy="12" r="5"/></svg>
            </span>
            <!-- Node: right -->
            <span class="absolute right-0 top-1/2 -translate-y-1/2 flex h-5 w-5 items-center justify-center rounded-full bg-cyan-600/70 shadow-lg shadow-cyan-500/30">
              <svg viewBox="0 0 24 24" class="h-2.5 w-2.5" fill="currentColor" stroke="none"><circle cx="12" cy="12" r="5"/></svg>
            </span>
            <!-- Node: bottom -->
            <span class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex h-5 w-5 items-center justify-center rounded-full bg-blue-500/60 shadow-lg shadow-blue-400/20">
              <svg viewBox="0 0 24 24" class="h-2.5 w-2.5" fill="currentColor" stroke="none"><circle cx="12" cy="12" r="5"/></svg>
            </span>
            <!-- Node: left -->
            <span class="absolute left-0 top-1/2 -translate-y-1/2 flex h-4 w-4 items-center justify-center rounded-full bg-cyan-500/50 shadow-lg shadow-cyan-400/20">
              <svg viewBox="0 0 24 24" class="h-2 w-2" fill="currentColor" stroke="none"><circle cx="12" cy="12" r="5"/></svg>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="animate-fade-in-up mt-16 flex flex-col items-center gap-2 text-slate-500" style="animation-delay: 0.8s;">
      <span class="text-xs uppercase tracking-widest">스크롤</span>
      <svg
        class="h-5 w-5 animate-bounce"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m6 9 6 6 6-6" />
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes orbit {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
</style>
