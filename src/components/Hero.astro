---
import type { Locale } from '../i18n/index';
import { localePath } from '../i18n/index';
import { t } from '../i18n/ui';
import { getCompany } from '../data/company';

interface Props {
  lang?: Locale;
}

const { lang = 'ko' } = Astro.props;
const company = getCompany(lang);
---

<section class="border-b border-slate-800 bg-navy-900">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-16 sm:py-20 lg:grid-cols-[1fr_360px] lg:px-8">
    <div class="max-w-3xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-widest text-blue-300">BlueSecurity</p>

      <h1 class="text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">
        {company.slogan}
      </h1>

      <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
        {company.description}
      </p>
      <p class="mt-3 max-w-2xl text-base leading-7 text-slate-400">
        {company.mission}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="https://codeblue.bluesecurity.online"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-navy-900"
        >
          {t('hero.cta.start', lang)}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>

        <a
          href={localePath('/contact', lang)}
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-500 hover:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-navy-900"
        >
          {t('hero.cta.contact', lang)}
        </a>
      </div>
    </div>

    <aside class="self-end border-l border-slate-800 pl-6 lg:mt-10">
      <p class="text-sm font-semibold text-slate-300">{t('hero.scope.heading', lang)}</p>
      <ul class="mt-5 space-y-4">
        <li>
          <p class="text-sm font-medium text-white">{t('hero.scope.code.title', lang)}</p>
          <p class="mt-1 text-sm leading-6 text-slate-500">{t('hero.scope.code.desc', lang)}</p>
        </li>
        <li>
          <p class="text-sm font-medium text-white">{t('hero.scope.consulting.title', lang)}</p>
          <p class="mt-1 text-sm leading-6 text-slate-500">{t('hero.scope.consulting.desc', lang)}</p>
        </li>
      </ul>
    </aside>
  </div>
</section>
