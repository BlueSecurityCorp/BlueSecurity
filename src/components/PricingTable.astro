---
import type { Locale } from '../i18n/index';
import { localePath } from '../i18n/index';
import { t } from '../i18n/ui';
import { getPricing } from '../data/pricing.ts';

interface Props {
  lang?: Locale;
}

const { lang = 'ko' } = Astro.props;
const products = getPricing(lang);

const tierIcons: Record<string, string> = {
  Free: '◉',
  Trial: '⬡',
  Starter: '◈',
  Pro: '◉',
  Business: '◆',
  Standard: '◇',
  Professional: '◉',
  Enterprise: '◆',
};
---

<section class="w-full space-y-16">
  {
    products.map((product) => (
      <div>
        {/* Product heading */}
        <h2 class="mb-6 text-2xl font-bold text-white">{product.productName}</h2>

        {/* Tiers grid */}
        <div
          class={
            product.tiers.length === 1
              ? 'mx-auto grid max-w-xl grid-cols-1 gap-6'
              : 'grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4'
          }
        >
          {product.tiers.map((tier) => (
            <div
              class={[
                'relative flex flex-col rounded-lg border p-6 transition-colors duration-200',
                tier.highlighted
                  ? 'border-blue-700 bg-navy-900'
                  : 'border-slate-800 bg-navy-900 hover:border-slate-600',
              ].join(' ')}
            >
              {/* Popular badge */}
              {tier.highlighted && (
                <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                  <span class="inline-flex items-center gap-1 rounded-md bg-blue-600 px-3 py-1 text-xs font-semibold tracking-wide text-white">
                    {t('pricing.recommended', lang)}
                  </span>
                </div>
              )}

              {/* Header */}
              <div class="mb-5">
                <div class="mb-3 flex items-center gap-2">
                  <span class="text-lg text-blue-400">{tierIcons[tier.name] ?? '◇'}</span>
                  <h3 class="text-lg font-bold text-white">{tier.name}</h3>
                </div>
                <p class="mb-4 text-sm text-slate-400">{tier.description}</p>

                {/* Price */}
                <div class="flex items-baseline gap-1">
                  {tier.price === '0' ? (
                    <span class="text-4xl font-extrabold text-white">{t('pricing.free', lang)}</span>
                  ) : tier.price === '문의하기' || tier.price === 'Contact Us' ? (
                    <span class="text-2xl font-extrabold text-white">{tier.price}</span>
                  ) : (
                    <>
                      <span class="text-sm font-medium text-slate-400">₩</span>
                      <span class="text-4xl font-extrabold text-white">
                        {tier.price}
                      </span>
                      {tier.period && (
                        <span class="text-sm text-slate-400">{tier.period}</span>
                      )}
                    </>
                  )}
                </div>
              </div>

              {/* Divider */}
              <div
                class={[
                  'mb-5 h-px w-full',
                  tier.highlighted ? 'bg-blue-900/60' : 'bg-slate-800',
                ].join(' ')}
              />

              {/* Features */}
              <ul class="mb-6 flex-1 space-y-2.5">
                {tier.features.map((feature) => (
                  <li class="flex items-start gap-2.5 text-sm">
                    <svg
                      class="mt-0.5 h-4 w-4 shrink-0 text-blue-400"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                    >
                      <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" />
                      <path
                        d="M5 8l2 2 4-4"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    <span class="text-slate-300">{feature}</span>
                  </li>
                ))}
              </ul>

              {/* CTA */}
              <a
                href={
                  tier.cta === '문의하기' || tier.cta === 'Contact Us'
                    ? localePath('/contact', lang)
                    : product.productId === 'codeblue'
                      ? 'https://codeblue.bluesecurity.online'
                      : localePath('/contact', lang)
                }
                target={
                  (tier.cta === '문의하기' || tier.cta === 'Contact Us') ||
                  product.productId !== 'codeblue'
                    ? undefined
                    : '_blank'
                }
                rel={
                  (tier.cta === '문의하기' || tier.cta === 'Contact Us') ||
                  product.productId !== 'codeblue'
                    ? undefined
                    : 'noopener noreferrer'
                }
                class={[
                  'mt-auto block rounded-xl px-4 py-2.5 text-center text-sm font-semibold transition-all duration-200',
                  tier.highlighted
                    ? 'bg-blue-600 text-white hover:bg-blue-500'
                    : tier.cta === '문의하기' || tier.cta === 'Contact Us'
                      ? 'border border-slate-700 text-blue-300 hover:bg-slate-900'
                      : 'border border-slate-700 text-slate-200 hover:border-slate-500 hover:text-white',
                ].join(' ')}
              >
                {tier.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    ))
  }
</section>
