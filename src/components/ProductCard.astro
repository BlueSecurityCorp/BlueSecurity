---
export interface Props {
  name: string;
  tagline: string;
  href: string;
  icon: 'code' | 'shield' | 'network' | 'pentest';
  category: string;
  highlights: { label: string; value: string }[];
  description: string;
}

const { name, tagline, href, icon, category, highlights, description } = Astro.props;
---

<a
  href={href}
  class="card-hover group relative flex flex-col overflow-hidden rounded-2xl border border-slate-700/60 bg-navy-800/70 p-8 backdrop-blur-sm transition-colors duration-300 hover:border-blue-500/50 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-navy-900"
  aria-label={`${name} - ${tagline}`}
>
  <!-- Gradient top border accent -->
  <span
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-blue-500/60 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
    aria-hidden="true"
  ></span>

  <!-- Glow backdrop on hover -->
  <span
    class="pointer-events-none absolute inset-0 rounded-2xl bg-blue-600/0 transition-all duration-300 group-hover:bg-blue-600/5"
    aria-hidden="true"
  ></span>

  <!-- Icon -->
  <div class="relative mb-6 flex h-14 w-14 items-center justify-center rounded-xl border border-blue-500/30 bg-blue-950/60 transition-all duration-300 group-hover:border-blue-400/60 group-hover:bg-blue-900/40 group-hover:shadow-lg group-hover:shadow-blue-600/20">
    {icon === 'code' && (
      <svg
        class="h-7 w-7 text-blue-400 transition-colors duration-200 group-hover:text-cyan-400"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="16 18 22 12 16 6" />
        <polyline points="8 6 2 12 8 18" />
      </svg>
    )}
    {icon === 'shield' && (
      <svg
        class="h-7 w-7 text-blue-400 transition-colors duration-200 group-hover:text-cyan-400"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        <path d="m9 12 2 2 4-4" />
      </svg>
    )}
    {icon === 'network' && (
      <svg
        class="h-7 w-7 text-blue-400 transition-colors duration-200 group-hover:text-cyan-400"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="5"  r="2" />
        <circle cx="5"  cy="19" r="2" />
        <circle cx="19" cy="19" r="2" />
        <line x1="12" y1="7"  x2="5"  y2="17" />
        <line x1="12" y1="7"  x2="19" y2="17" />
        <line x1="5"  y1="19" x2="19" y2="19" />
      </svg>
    )}
    {icon === 'pentest' && (
      <svg
        class="h-7 w-7 text-blue-400 transition-colors duration-200 group-hover:text-cyan-400"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        <path d="M12 8v4" />
        <circle cx="12" cy="16" r="1" fill="currentColor" stroke="none" />
      </svg>
    )}
  </div>

  <!-- Category badge -->
  <span class="mb-3 inline-flex w-fit items-center rounded-full bg-blue-950/80 px-3 py-1 text-xs font-medium text-blue-300 ring-1 ring-blue-500/20">
    {category}
  </span>

  <!-- Product name -->
  <h3 class="mb-2 text-xl font-bold text-white transition-colors duration-200 group-hover:text-cyan-300">
    {name}
  </h3>

  <!-- Tagline -->
  <p class="mb-4 text-sm font-medium text-blue-400">
    {tagline}
  </p>

  <!-- Description -->
  <p class="mb-6 line-clamp-3 flex-1 text-sm leading-relaxed text-slate-400">
    {description}
  </p>

  <!-- Highlights -->
  <div class="mb-6 grid grid-cols-3 gap-3">
    {highlights.map((h) => (
      <div class="rounded-lg bg-navy-900/60 px-3 py-2.5 text-center">
        <div class="text-lg font-black text-gradient leading-none">{h.value}</div>
        <div class="mt-1 text-[10px] text-slate-500">{h.label}</div>
      </div>
    ))}
  </div>

  <!-- CTA row -->
  <div class="flex items-center gap-2 text-sm font-semibold text-blue-400 transition-colors duration-200 group-hover:text-cyan-300">
    자세히 보기
    <svg
      class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </div>
</a>
