---
import type { Locale } from '../i18n/index';
import { localePath } from '../i18n/index';
import { t } from '../i18n/ui';
import { getCompany } from '../data/company';
import { getProducts } from '../data/products';

interface Props {
  lang?: Locale;
}

const { lang = 'ko' } = Astro.props;
const company = getCompany(lang);
const products = getProducts(lang);
const currentYear = new Date().getFullYear();

const companyLinks = [
  { href: localePath('/about', lang), label: t('nav.about', lang) },
  { href: localePath('/pricing', lang), label: t('nav.pricing', lang) },
  { href: localePath('/contact', lang), label: t('nav.contact', lang) },
];

// Placeholder social links — swap hrefs when accounts are live
const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/bluesecurity',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
    </svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/company/bluesecurity',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>`,
  },
  {
    label: '이메일',
    href: `mailto:${company.email}`,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2"/>
      <path d="M2 7l10 7 10-7"/>
    </svg>`,
  },
];
---

<footer class="site-footer">
  <!-- Top decorative border -->
  <div class="footer-border-gradient" aria-hidden="true"></div>

  <div class="footer-container">
    <!-- Main footer grid -->
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href={localePath('/', lang)} class="footer-logo" aria-label={t('nav.home', lang)}>
          <span class="footer-logo-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M14 2L4 7v7c0 5.5 4.3 10.6 10 11.9C19.7 24.6 24 19.5 24 14V7L14 2z"
                stroke="url(#footer-shield-grad)"
                stroke-width="1.8"
                stroke-linejoin="round"
                fill="none"
              />
              <path
                d="M10 14l3 3 5-5"
                stroke="url(#footer-check-grad)"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <defs>
                <linearGradient id="footer-shield-grad" x1="4" y1="2" x2="24" y2="26" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#60a5fa" />
                  <stop offset="100%" stop-color="#22d3ee" />
                </linearGradient>
                <linearGradient id="footer-check-grad" x1="10" y1="14" x2="18" y2="17" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#60a5fa" />
                  <stop offset="100%" stop-color="#22d3ee" />
                </linearGradient>
              </defs>
            </svg>
          </span>
          <span class="footer-logo-text">
            Blue<span class="footer-logo-accent">Security</span>
          </span>
        </a>

        <p class="footer-slogan">{company.slogan}</p>
        <p class="footer-description">{company.description}</p>

        <!-- Social links -->
        <div class="footer-social" role="list" aria-label="소셜 미디어 링크">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              class="social-link"
              aria-label={link.label}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              role="listitem"
              set:html={link.icon}
            />
          ))}
        </div>
      </div>

      <!-- Products column -->
      <div class="footer-nav-col">
        <h3 class="footer-col-heading">{t('footer.products', lang)}</h3>
        <ul class="footer-nav-list" role="list">
          {products.map((product) => (
            <li>
              <a href={product.href} class="footer-nav-link">
                <span class="footer-link-dot" aria-hidden="true"></span>
                {product.name}
                <span class="footer-link-badge">{product.category.split(' ')[0]}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div class="footer-nav-col">
        <h3 class="footer-col-heading">{t('footer.company', lang)}</h3>
        <ul class="footer-nav-list" role="list">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-nav-link">
                <span class="footer-link-dot" aria-hidden="true"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div class="footer-nav-col">
        <h3 class="footer-col-heading">{t('footer.contact', lang)}</h3>
        <ul class="footer-contact-list" role="list">
          <li>
            <a href={`mailto:${company.email}`} class="footer-contact-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M2 7l10 7 10-7"/>
              </svg>
              {company.email}
            </a>
          </li>
          <li class="footer-contact-note">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            {t('footer.hours', lang)}
          </li>
        </ul>

        <!-- CTA card -->
        <div class="footer-cta-card">
          <p class="footer-cta-text">{t('footer.consult', lang)}</p>
          <a href={localePath('/contact', lang)} class="footer-cta-btn">{t('footer.consult.cta', lang)}</a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {currentYear} BlueSecurity. All rights reserved.
      </p>
      <div class="footer-bottom-links">
        <a href={localePath('/privacy', lang)} class="footer-bottom-link">{t('footer.privacy', lang)}</a>
        <span class="footer-divider" aria-hidden="true">/</span>
        <a href={localePath('/terms', lang)} class="footer-bottom-link">{t('footer.terms', lang)}</a>
        <span class="footer-divider" aria-hidden="true">/</span>
        <span class="footer-founded">{t('footer.founded', lang)} {company.founded}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ── Footer base ─────────────────────────────────────────────────── */
  .site-footer {
    position: relative;
    background-color: var(--color-navy-900);
    margin-top: auto;
  }

  .footer-border-gradient {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(59, 130, 246, 0.3) 25%,
      rgba(34, 211, 238, 0.4) 50%,
      rgba(59, 130, 246, 0.3) 75%,
      transparent 100%
    );
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2rem;
  }

  /* ── Grid layout ─────────────────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 3rem;
    }
  }

  /* ── Brand column ────────────────────────────────────────────────── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    width: fit-content;
  }

  .footer-logo-icon {
    display: flex;
    align-items: center;
    filter: drop-shadow(0 0 6px rgba(96, 165, 250, 0.35));
  }

  .footer-logo-text {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #e2e8f0;
    font-family: var(--font-sans);
  }

  .footer-logo-accent {
    background: linear-gradient(135deg, #60a5fa, #22d3ee);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-slogan {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #60a5fa;
    margin: 0;
  }

  .footer-description {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0;
    max-width: 320px;
  }

  /* Social links */
  .footer-social {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 0.5rem;
    background-color: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.15);
    color: #64748b;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .social-link:hover {
    background-color: rgba(59, 130, 246, 0.18);
    color: #60a5fa;
    border-color: rgba(59, 130, 246, 0.35);
  }

  /* ── Nav columns ─────────────────────────────────────────────────── */
  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-col-heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #475569;
    margin: 0;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid rgba(59, 130, 246, 0.08);
  }

  .footer-nav-list {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0;
    font-size: 0.875rem;
    color: #64748b;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-nav-link:hover {
    color: #94a3b8;
  }

  .footer-link-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: rgba(59, 130, 246, 0.35);
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }

  .footer-nav-link:hover .footer-link-dot {
    background-color: #60a5fa;
  }

  .footer-link-badge {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #334155;
    background-color: rgba(59, 130, 246, 0.06);
    border: 1px solid rgba(59, 130, 246, 0.1);
    border-radius: 0.25rem;
    padding: 0.05rem 0.35rem;
    white-space: nowrap;
    margin-left: auto;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .footer-nav-link:hover .footer-link-badge {
    color: #475569;
    border-color: rgba(59, 130, 246, 0.2);
  }

  /* ── Contact column ──────────────────────────────────────────────── */
  .footer-contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #64748b;
    text-decoration: none;
    transition: color 0.2s ease;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .footer-contact-link:hover {
    color: #60a5fa;
  }

  .footer-contact-note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #475569;
  }

  /* CTA card */
  .footer-cta-card {
    margin-top: 0.5rem;
    padding: 0.875rem 1rem;
    border-radius: 0.625rem;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.15), rgba(8, 145, 178, 0.1));
    border: 1px solid rgba(59, 130, 246, 0.2);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-cta-text {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #93c5fd;
    margin: 0;
  }

  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0.875rem;
    border-radius: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(135deg, #2563eb, #0891b2);
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
    width: fit-content;
  }

  .footer-cta-btn:hover {
    opacity: 0.9;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.35);
  }

  /* ── Bottom bar ──────────────────────────────────────────────────── */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    text-align: center;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(59, 130, 246, 0.08);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-copyright {
    font-size: 0.8125rem;
    color: #334155;
    margin: 0;
  }

  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .footer-bottom-links {
      justify-content: flex-end;
    }
  }

  .footer-bottom-link {
    font-size: 0.75rem;
    color: #334155;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-bottom-link:hover {
    color: #60a5fa;
  }

  .footer-divider {
    color: #1e293b;
    font-size: 0.75rem;
  }

  .footer-founded {
    font-size: 0.75rem;
    color: #2d3748;
  }
</style>
