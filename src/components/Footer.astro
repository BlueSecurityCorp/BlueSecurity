---
import type { Locale } from '../i18n/index';
import { localePath } from '../i18n/index';
import { t } from '../i18n/ui';
import { getCompany } from '../data/company';
import { getProductLineup } from '../data/products';

interface Props {
  lang?: Locale;
}

const { lang = 'ko' } = Astro.props;
const company = getCompany(lang);
const products = getProductLineup(lang);
const currentYear = new Date().getFullYear();

const companyLinks = [
  { href: localePath('/about', lang), label: t('nav.about', lang) },
  { href: localePath('/pricing', lang), label: t('nav.pricing', lang) },
  { href: localePath('/notices', lang), label: t('nav.notices', lang) },
  { href: localePath('/careers', lang), label: t('nav.careers', lang) },
  { href: localePath('/contact', lang), label: t('nav.contact', lang) },
];

const socialLinks = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/블루시큐리티' },
  { label: 'GitHub', href: 'https://github.com/BlueSecurityCorp' },
  { label: t('footer.email', lang), href: `mailto:${company.email}` },
];
---

<footer class="site-footer">
  <div class="footer-border-gradient" aria-hidden="true"></div>

  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={localePath('/', lang)} class="footer-logo" aria-label={t('nav.home', lang)}>
          <span class="footer-logo-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 2L4 7v7c0 5.5 4.3 10.6 10 11.9C19.7 24.6 24 19.5 24 14V7L14 2z" stroke="url(#footer-shield-grad)" stroke-width="1.8" stroke-linejoin="round" fill="none" />
              <path d="M10 14l3 3 5-5" stroke="url(#footer-check-grad)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              <defs>
                <linearGradient id="footer-shield-grad" x1="4" y1="2" x2="24" y2="26" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#60a5fa" />
                  <stop offset="100%" stop-color="#22d3ee" />
                </linearGradient>
                <linearGradient id="footer-check-grad" x1="10" y1="14" x2="18" y2="17" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#60a5fa" />
                  <stop offset="100%" stop-color="#22d3ee" />
                </linearGradient>
              </defs>
            </svg>
          </span>
          <span class="footer-logo-text">Blue<span class="footer-logo-accent">Security</span></span>
        </a>

        <p class="footer-slogan">{company.slogan}</p>
        <p class="footer-description">{company.description}</p>

        <div class="footer-social" role="list" aria-label="Social links">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              class="social-link"
              aria-label={link.label}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              role="listitem"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <div class="footer-nav-col">
        <h3 class="footer-col-heading">{t('footer.products', lang)}</h3>
        <ul class="footer-nav-list" role="list">
          {products.map((product) => (
            <li>
              <a href={product.href} class="footer-nav-link">
                <span class="footer-link-dot" aria-hidden="true"></span>
                {product.name}
                <span class="footer-link-badge">{product.category.split(' ')[0]}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-nav-col">
        <h3 class="footer-col-heading">{t('footer.company', lang)}</h3>
        <ul class="footer-nav-list" role="list">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-nav-link">
                <span class="footer-link-dot" aria-hidden="true"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-nav-col">
        <h3 class="footer-col-heading">{t('footer.contact', lang)}</h3>
        <ul class="footer-contact-list" role="list">
          <li>
            <a href={`mailto:${company.email}`} class="footer-contact-link">{company.email}</a>
          </li>
          <li class="footer-contact-note">{t('footer.hours', lang)}</li>
        </ul>

        <div class="footer-cta-card">
          <p class="footer-cta-text">{t('footer.contact.prompt', lang)}</p>
          <a href={localePath('/contact', lang)} class="footer-cta-btn">{t('footer.contact.cta', lang)}</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {currentYear} BlueSecurity. All rights reserved.</p>
      <div class="footer-bottom-links">
        <a href={localePath('/privacy', lang)} class="footer-bottom-link">{t('footer.privacy', lang)}</a>
        <span class="footer-divider" aria-hidden="true">/</span>
        <a href={localePath('/terms', lang)} class="footer-bottom-link">{t('footer.terms', lang)}</a>
        <span class="footer-divider" aria-hidden="true">/</span>
        <span class="footer-founded">{t('footer.founded', lang)} {company.founded}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: auto;
    background-color: var(--color-navy-900);
  }

  .footer-border-gradient {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(59, 130, 246, 0.3) 25%, rgba(34, 211, 238, 0.4) 50%, rgba(59, 130, 246, 0.3) 75%, transparent 100%);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 3rem;
    }
  }

  .footer-brand,
  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    text-decoration: none;
  }

  .footer-logo-icon {
    display: flex;
    align-items: center;
    filter: drop-shadow(0 0 6px rgba(96, 165, 250, 0.35));
  }

  .footer-logo-text {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #e2e8f0;
  }

  .footer-logo-accent {
    background: linear-gradient(135deg, #60a5fa, #22d3ee);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-slogan {
    margin: 0;
    color: #60a5fa;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .footer-description {
    max-width: 320px;
    margin: 0;
    color: #64748b;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .social-link,
  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.4rem;
    text-decoration: none;
    transition: opacity 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .social-link {
    border: 1px solid rgba(59, 130, 246, 0.15);
    background-color: rgba(59, 130, 246, 0.08);
    padding: 0.45rem 0.6rem;
    color: #64748b;
    font-size: 0.75rem;
  }

  .social-link:hover {
    color: #60a5fa;
    background-color: rgba(59, 130, 246, 0.18);
  }

  .footer-col-heading {
    margin: 0;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid rgba(59, 130, 246, 0.08);
    color: #475569;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-nav-list,
  .footer-contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-nav-link,
  .footer-contact-link,
  .footer-contact-note,
  .footer-bottom-link,
  .footer-founded,
  .footer-copyright {
    color: #64748b;
    font-size: 0.8125rem;
    text-decoration: none;
  }

  .footer-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0;
  }

  .footer-nav-link:hover,
  .footer-contact-link:hover,
  .footer-bottom-link:hover {
    color: #60a5fa;
  }

  .footer-link-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: rgba(59, 130, 246, 0.35);
    flex-shrink: 0;
  }

  .footer-link-badge {
    margin-left: auto;
    border: 1px solid rgba(59, 130, 246, 0.1);
    border-radius: 0.25rem;
    background-color: rgba(59, 130, 246, 0.06);
    padding: 0.05rem 0.35rem;
    color: #334155;
    font-size: 0.6875rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .footer-cta-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.5rem;
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 0.625rem;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.15), rgba(8, 145, 178, 0.1));
    padding: 0.875rem 1rem;
  }

  .footer-cta-text {
    margin: 0;
    color: #93c5fd;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .footer-cta-btn {
    width: fit-content;
    background: linear-gradient(135deg, #2563eb, #0891b2);
    padding: 0.5rem 0.875rem;
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .footer-cta-btn:hover {
    opacity: 0.9;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    margin-top: 3rem;
    border-top: 1px solid rgba(59, 130, 246, 0.08);
    padding-top: 1.5rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-bottom-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .footer-copyright,
  .footer-bottom-link,
  .footer-founded,
  .footer-divider {
    color: #334155;
    font-size: 0.75rem;
  }

  .footer-divider {
    color: #1e293b;
  }
</style>
