---
import type { Locale } from '../i18n/index';
import { localePath } from '../i18n/index';
import { t } from '../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = 'ko' } = Astro.props;
---

<section class="bg-navy-900 py-14" aria-labelledby="cta-heading">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid items-center gap-6 rounded-lg border border-slate-800 bg-slate-950/50 p-6 md:grid-cols-[1fr_auto] md:p-8">
      <div>
        <h2 id="cta-heading" class="text-3xl font-semibold text-white md:text-4xl">
          {t('cta.heading.prefix', lang)}<span class="text-blue-300">{t('cta.heading.accent', lang)}</span>
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
          {t('cta.description', lang)}
        </p>
        <p class="mt-2 max-w-2xl text-sm text-slate-500">
          {t('cta.trust', lang)}
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row md:flex-col lg:flex-row">
        <a
          href="https://codeblue.bluesecurity.online"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-navy-900"
        >
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="16 18 22 12 16 6" />
            <polyline points="8 6 2 12 8 18" />
          </svg>
          {t('cta.button.start', lang)}
        </a>

        <a
          href={localePath('/contact', lang)}
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-500 hover:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-navy-900"
        >
          <svg class="h-4 w-4 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
          </svg>
          {t('cta.button.contact', lang)}
        </a>
      </div>
    </div>
  </div>
</section>
