---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/ui';
import { getTechHighlights } from '../data/company';

interface Props {
  lang?: Locale;
}

const { lang = 'ko' } = Astro.props;
const techHighlights = getTechHighlights(lang);

const icons = [
  `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a4 4 0 0 1 4 4c0 .34-.04.67-.1 1H16a4 4 0 0 1 4 4 4 4 0 0 1-4 4h-.1c.06.33.1.66.1 1a4 4 0 0 1-4 4 4 4 0 0 1-4-4c0-.34.04-.67.1-1H8a4 4 0 0 1-4-4 4 4 0 0 1 4-4h.1A4 4 0 0 1 8 6a4 4 0 0 1 4-4z"/></svg>`,
  `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  `<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
];
---

<section class="border-b border-slate-800 bg-slate-950/40 py-14" aria-labelledby="trust-why-heading">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 max-w-3xl">
      <h3 id="trust-why-heading" class="text-3xl font-semibold text-white md:text-4xl">
        {t('trust.why.heading', lang)}
      </h3>
      <p class="mt-3 text-slate-400">{t('trust.why.subtitle', lang)}</p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {techHighlights.map((item, i) => (
        <div class="rounded-lg border border-slate-800 bg-navy-900 p-6 transition-colors duration-200 hover:border-slate-600">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-slate-700 bg-slate-950 text-blue-300">
            <Fragment set:html={icons[i] ?? icons[0]} />
          </div>
          <h4 class="mb-2 font-semibold text-white">{item.title}</h4>
          <p class="text-sm leading-relaxed text-slate-400">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
