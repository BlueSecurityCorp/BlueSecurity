---
import type { Locale } from '../i18n/index';
import { localePath, switchLocalePath } from '../i18n/index';
import { t } from '../i18n/ui';
import { getProductLineup } from '../data/products';

interface Props {
  lang?: Locale;
}

const { lang = 'ko' } = Astro.props;
const products = getProductLineup(lang);
const currentPath = Astro.url.pathname;
const koPath = switchLocalePath(currentPath, 'ko');
const enPath = switchLocalePath(currentPath, 'en');

function isActive(path: string) {
  return path === '/' ? currentPath === '/' : currentPath.startsWith(path);
}
---

<header class="site-header">
  <nav class="nav-inner">
    <a href={localePath('/', lang)} class="brand" aria-label={t('nav.home', lang)}>
      <span class="brand-mark" aria-hidden="true">◆</span>
      <span>Blue<span>Security</span></span>
    </a>

    <input id="mobile-menu-toggle" class="menu-checkbox" type="checkbox" aria-hidden="true" />
    <label class="menu-toggle" for="mobile-menu-toggle" aria-label="메뉴 열기">
      <span></span><span></span><span></span>
    </label>

    <div class="nav-links">
      <a href={localePath('/about', lang)} class:list={['nav-link', { active: isActive('/about') }]}>{t('nav.about', lang)}</a>

      <div class="products-menu">
        <a href={localePath('/products', lang)} class:list={['nav-link', { active: isActive('/products') }]}>{t('nav.products', lang)}</a>
        <div class="products-dropdown">
          <p>{t('nav.products.lineup', lang)}</p>
          {products.map((product) => (
            <a href={product.href} class="product-link">
              <strong>{product.name}</strong>
              <span>{product.tagline}</span>
            </a>
          ))}
          <a href={localePath('/pricing', lang)} class="product-link pricing-link">{t('nav.pricing.view', lang)}</a>
        </div>
      </div>

      <a href={localePath('/pricing', lang)} class:list={['nav-link', { active: isActive('/pricing') }]}>{t('nav.pricing', lang)}</a>
      <a href={localePath('/notices', lang)} class:list={['nav-link', { active: isActive('/notices') }]}>{t('nav.notices', lang)}</a>
      <a href={localePath('/careers', lang)} class:list={['nav-link', { active: isActive('/careers') }]}>{t('nav.careers', lang)}</a>
      <a href={localePath('/contact', lang)} class="nav-cta">{t('nav.contact', lang)}</a>

      <div class="lang-switch" aria-label="Language">
        <a href={koPath} class:list={[{ active: lang === 'ko' }]} hreflang="ko">KO</a>
        <span>|</span>
        <a href={enPath} class:list={[{ active: lang === 'en' }]} hreflang="en">EN</a>
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(59, 130, 246, 0.12);
    background: color-mix(in srgb, var(--color-navy-900) 88%, transparent);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    height: 64px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: #e2e8f0;
    font-weight: 700;
    text-decoration: none;
  }

  .brand span span,
  .brand-mark {
    color: #60a5fa;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link,
  .nav-cta,
  .lang-switch a,
  .product-link {
    text-decoration: none;
  }

  .nav-link {
    border-radius: 0.5rem;
    padding: 0.5rem 0.875rem;
    color: #94a3b8;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .nav-link:hover,
  .nav-link.active {
    background: rgba(59, 130, 246, 0.1);
    color: #60a5fa;
  }

  .nav-cta {
    border: 1px solid rgba(96, 165, 250, 0.3);
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #2563eb, #0891b2);
    padding: 0.5rem 1.125rem;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .products-menu {
    position: relative;
  }

  .products-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    display: none;
    width: 300px;
    transform: translateX(-50%);
    border: 1px solid rgba(59, 130, 246, 0.18);
    border-radius: 0.75rem;
    background: var(--color-navy-800);
    padding: 0.5rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
  }

  .products-menu:hover .products-dropdown,
  .products-menu:focus-within .products-dropdown {
    display: block;
  }

  .products-dropdown p {
    margin: 0;
    padding: 0.35rem 0.6rem;
    color: #475569;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-link {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    border-radius: 0.5rem;
    padding: 0.65rem 0.75rem;
    color: #cbd5e1;
  }

  .product-link:hover {
    background: rgba(59, 130, 246, 0.1);
  }

  .product-link span {
    color: #64748b;
    font-size: 0.75rem;
  }

  .pricing-link {
    margin-top: 0.35rem;
    border-top: 1px solid rgba(59, 130, 246, 0.1);
    color: #60a5fa;
    font-size: 0.8rem;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.5rem;
  }

  .lang-switch a,
  .lang-switch span {
    color: #64748b;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .lang-switch a.active {
    color: #60a5fa;
  }

  .menu-checkbox,
  .menu-toggle {
    display: none;
  }

  @media (max-width: 767px) {
    .menu-toggle {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
    }

    .menu-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      border-radius: 2px;
      background: #94a3b8;
    }

    .nav-links {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      display: none;
      flex-direction: column;
      align-items: stretch;
      border-top: 1px solid rgba(59, 130, 246, 0.1);
      background: var(--color-navy-900);
      padding: 1rem;
    }

    .menu-checkbox:checked ~ .nav-links {
      display: flex;
    }

    .products-dropdown {
      position: static;
      display: block;
      width: auto;
      transform: none;
      box-shadow: none;
    }
  }
</style>
