---
import { products } from '../data/products';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <nav class="nav-inner">
    <!-- Logo -->
    <a href="/" class="logo-link" aria-label="BlueSecurity 홈">
      <span class="logo-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M14 2L4 7v7c0 5.5 4.3 10.6 10 11.9C19.7 24.6 24 19.5 24 14V7L14 2z"
            fill="none"
            stroke="url(#shield-grad)"
            stroke-width="1.8"
            stroke-linejoin="round"
          />
          <path
            d="M10 14l3 3 5-5"
            stroke="url(#check-grad)"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <defs>
            <linearGradient id="shield-grad" x1="4" y1="2" x2="24" y2="26" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#60a5fa" />
              <stop offset="100%" stop-color="#22d3ee" />
            </linearGradient>
            <linearGradient id="check-grad" x1="10" y1="14" x2="18" y2="17" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#60a5fa" />
              <stop offset="100%" stop-color="#22d3ee" />
            </linearGradient>
          </defs>
        </svg>
      </span>
      <span class="logo-text">Blue<span class="logo-text-accent">Security</span></span>
    </a>

    <!-- Desktop Navigation -->
    <ul class="desktop-nav" role="list">
      <li>
        <a
          href="/about"
          class:list={['nav-link', { 'nav-link--active': isActive('/about') }]}
        >
          회사 소개
        </a>
      </li>

      <!-- Products dropdown -->
      <li class="dropdown-wrapper" aria-haspopup="true">
        <button
          class:list={['nav-link', 'dropdown-trigger', { 'nav-link--active': isActive('/products') }]}
          aria-expanded="false"
          aria-controls="products-dropdown"
          type="button"
        >
          제품
          <svg class="dropdown-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div id="products-dropdown" class="dropdown-menu" role="menu">
          <div class="dropdown-header">
            <span class="dropdown-header-label">제품 라인업</span>
          </div>
          {products.map((product) => (
            <a
              href={product.href}
              class:list={['dropdown-item', { 'dropdown-item--active': currentPath === product.href }]}
              role="menuitem"
            >
              <span class="dropdown-item-icon" aria-hidden="true">
                {product.icon === 'code' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M5 4L1 8l4 4M11 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                )}
                {product.icon === 'shield' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 1L2 4v4c0 3.3 2.6 6.3 6 7 3.4-.7 6-3.7 6-7V4L8 1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  </svg>
                )}
                {product.icon === 'network' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="2.5" cy="4" r="1.5" stroke="currentColor" stroke-width="1.3"/>
                    <circle cx="13.5" cy="4" r="1.5" stroke="currentColor" stroke-width="1.3"/>
                    <circle cx="2.5" cy="12" r="1.5" stroke="currentColor" stroke-width="1.3"/>
                    <circle cx="13.5" cy="12" r="1.5" stroke="currentColor" stroke-width="1.3"/>
                    <path d="M4 4.5L6.2 6.8M9.8 6.8L12 4.5M4 11.5L6.2 9.2M9.8 9.2L12 11.5" stroke="currentColor" stroke-width="1.3"/>
                  </svg>
                )}
              </span>
              <span class="dropdown-item-content">
                <span class="dropdown-item-name">{product.name}</span>
                <span class="dropdown-item-tagline">{product.tagline}</span>
              </span>
            </a>
          ))}
          <div class="dropdown-footer">
            <a href="/pricing" class="dropdown-footer-link">
              가격 보기
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </li>

      <li>
        <a
          href="/pricing"
          class:list={['nav-link', { 'nav-link--active': isActive('/pricing') }]}
        >
          가격
        </a>
      </li>

      <li>
        <a href="/contact" class="nav-cta">문의하기</a>
      </li>
    </ul>

    <!-- Mobile menu toggle (CSS-only using checkbox trick) -->
    <label class="mobile-toggle" for="mobile-menu-toggle" aria-label="메뉴 열기">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </label>
  </nav>

  <!-- Hidden checkbox for CSS-only mobile menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="mobile-menu-checkbox" aria-hidden="true" />

  <!-- Mobile Navigation -->
  <div class="mobile-nav" id="mobile-nav" role="dialog" aria-label="모바일 내비게이션">
    <div class="mobile-nav-inner">
      <a href="/about" class:list={['mobile-nav-link', { 'mobile-nav-link--active': isActive('/about') }]}>
        회사 소개
      </a>

      <!-- Mobile products section -->
      <div class="mobile-products-section">
        <span class="mobile-section-label">제품</span>
        {products.map((product) => (
          <a
            href={product.href}
            class:list={['mobile-nav-link', 'mobile-nav-link--product', { 'mobile-nav-link--active': currentPath === product.href }]}
          >
            <span class="mobile-product-name">{product.name}</span>
            <span class="mobile-product-tagline">{product.tagline}</span>
          </a>
        ))}
      </div>

      <a href="/pricing" class:list={['mobile-nav-link', { 'mobile-nav-link--active': isActive('/pricing') }]}>
        가격
      </a>

      <a href="/contact" class="mobile-nav-cta">
        문의하기
      </a>
    </div>
  </div>
</header>

<style>
  /* ── Header base ─────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    background-color: color-mix(in srgb, var(--color-navy-900) 85%, transparent);
    backdrop-filter: blur(12px) saturate(150%);
    -webkit-backdrop-filter: blur(12px) saturate(150%);
    border-bottom: 1px solid rgba(59, 130, 246, 0.12);
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }

  /* Scrolled state: slightly darker bg via @scroll is not supported in CSS alone,
     but backdrop-filter + semi-transparent bg achieves the blurred glass effect */

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
  }

  /* ── Logo ────────────────────────────────────────────────────────── */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 0 8px rgba(96, 165, 250, 0.4));
    transition: filter 0.3s ease;
  }

  .logo-link:hover .logo-icon {
    filter: drop-shadow(0 0 12px rgba(34, 211, 238, 0.5));
  }

  .logo-text {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #e2e8f0;
    font-family: var(--font-sans);
  }

  .logo-text-accent {
    background: linear-gradient(135deg, #60a5fa, #22d3ee);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Desktop nav ─────────────────────────────────────────────────── */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.875rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #94a3b8;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: color 0.2s ease, background-color 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link--active {
    color: #e2e8f0;
    background-color: rgba(59, 130, 246, 0.1);
  }

  .nav-link--active {
    color: #60a5fa;
  }

  /* CTA button */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.125rem;
    margin-left: 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(135deg, #2563eb, #0891b2);
    border: 1px solid rgba(96, 165, 250, 0.3);
    transition: opacity 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    font-family: var(--font-sans);
    white-space: nowrap;
  }

  .nav-cta:hover {
    opacity: 0.9;
    box-shadow: 0 0 16px rgba(59, 130, 246, 0.35);
    transform: translateY(-1px);
  }

  /* ── Dropdown ────────────────────────────────────────────────────── */
  .dropdown-wrapper {
    position: relative;
  }

  .dropdown-trigger {
    /* inherits .nav-link styles */
  }

  .dropdown-chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    background-color: var(--color-navy-800);
    border: 1px solid rgba(59, 130, 246, 0.18);
    border-radius: 0.75rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(59, 130, 246, 0.05);
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(-50%) translateY(-8px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 100;
  }

  /* Show dropdown on hover */
  .dropdown-wrapper:hover .dropdown-menu,
  .dropdown-wrapper:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* Rotate chevron on hover */
  .dropdown-wrapper:hover .dropdown-chevron,
  .dropdown-wrapper:focus-within .dropdown-chevron {
    transform: rotate(180deg);
  }

  .dropdown-header {
    padding: 0.375rem 0.625rem 0.25rem;
  }

  .dropdown-header-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #475569;
  }

  .dropdown-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: #cbd5e1;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .dropdown-item:hover,
  .dropdown-item--active {
    background-color: rgba(59, 130, 246, 0.1);
    color: #e2e8f0;
  }

  .dropdown-item--active .dropdown-item-name {
    color: #60a5fa;
  }

  .dropdown-item-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    border-radius: 0.4rem;
    background-color: rgba(59, 130, 246, 0.1);
    color: #60a5fa;
    margin-top: 1px;
  }

  .dropdown-item-content {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .dropdown-item-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #e2e8f0;
    line-height: 1.3;
  }

  .dropdown-item-tagline {
    font-size: 0.75rem;
    color: #64748b;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dropdown-footer {
    border-top: 1px solid rgba(59, 130, 246, 0.1);
    margin-top: 0.375rem;
    padding-top: 0.375rem;
  }

  .dropdown-footer-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.5rem;
    border-radius: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #60a5fa;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .dropdown-footer-link:hover {
    background-color: rgba(59, 130, 246, 0.1);
  }

  /* ── Mobile toggle ───────────────────────────────────────────────── */
  .mobile-menu-checkbox {
    display: none;
  }

  .mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    cursor: pointer;
    padding: 4px;
    border-radius: 0.375rem;
    transition: background-color 0.2s ease;
    flex-shrink: 0;
  }

  .mobile-toggle:hover {
    background-color: rgba(59, 130, 246, 0.1);
  }

  .hamburger-bar {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #94a3b8;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease, background-color 0.2s ease;
    transform-origin: center;
  }

  @media (min-width: 768px) {
    .mobile-toggle {
      display: none;
    }
  }

  /* ── Mobile nav ──────────────────────────────────────────────────── */
  .mobile-nav {
    display: none;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
    border-top: 1px solid rgba(59, 130, 246, 0.1);
  }

  /* Show mobile nav when checkbox is checked — checkbox is INSIDE header,
     so we can target .mobile-nav as a sibling of the checkbox */
  .mobile-menu-checkbox:checked ~ .mobile-nav {
    max-height: 600px;
  }

  @media (max-width: 767px) {
    .mobile-nav {
      display: block;
    }
  }

  .mobile-nav-inner {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.75rem 1rem 1rem;
  }

  .mobile-nav-link {
    display: flex;
    flex-direction: column;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: #94a3b8;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link--active {
    background-color: rgba(59, 130, 246, 0.08);
    color: #e2e8f0;
  }

  .mobile-nav-link--active {
    color: #60a5fa;
  }

  .mobile-products-section {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    border-top: 1px solid rgba(59, 130, 246, 0.08);
    border-bottom: 1px solid rgba(59, 130, 246, 0.08);
    padding: 0.5rem 0;
    margin: 0.25rem 0;
  }

  .mobile-section-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #475569;
    padding: 0.25rem 0.75rem;
  }

  .mobile-nav-link--product {
    padding-left: 1rem;
  }

  .mobile-product-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #cbd5e1;
  }

  .mobile-product-tagline {
    font-size: 0.75rem;
    color: #64748b;
    margin-top: 0.1rem;
  }

  .mobile-nav-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(135deg, #2563eb, #0891b2);
    border: 1px solid rgba(96, 165, 250, 0.25);
    transition: opacity 0.2s ease;
  }

  .mobile-nav-cta:hover {
    opacity: 0.88;
  }

  /* ── Hamburger X animation ───────────────────────────────────────── */
  /* Uses :has() — broadly supported in modern browsers */
  .site-header:has(.mobile-menu-checkbox:checked) .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background-color: #60a5fa;
  }

  .site-header:has(.mobile-menu-checkbox:checked) .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .site-header:has(.mobile-menu-checkbox:checked) .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background-color: #60a5fa;
  }

  /* Also highlight the toggle on active state */
  .site-header:has(.mobile-menu-checkbox:checked) .mobile-toggle {
    background-color: rgba(59, 130, 246, 0.12);
  }
</style>
